                    document.getElementById('loaiChietKhau').value = data.loaiChietKhau || 'Percentage';
                    document.getElementById('soDemToiThieu').value = data.soDemToiThieu || '';
                    document.getElementById('soNgayDatTruoc').value = data.soNgayDatTruoc || '';

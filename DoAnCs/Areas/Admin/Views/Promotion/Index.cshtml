        // Preview image
        document.getElementById('hinhAnhFile').addEventListener('change', function(e) {
            const file = e.target.files[0];
            const previewContainer = document.getElementById('imagePreview');
            const previewImage = document.getElementById('previewImage');

            if (file) {
                const validImageTypes = ['image/jpeg', 'image/png', 'image/gif'];
                if (!validImageTypes.includes(file.type)) {
                    showToast('Chỉ hỗ trợ định dạng .jpg, .jpeg, .png, .gif', false);
                    e.target.value = '';
                    previewContainer.classList.add('hidden');
                    return;
                }

                previewImage.src = URL.createObjectURL(file);
                previewContainer.classList.remove('hidden');
            } else {
                previewContainer.classList.add('hidden');
                previewImage.src = '';
            }
        });

        // Save promotion
        document.getElementById('promotionForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            console.log('Debug: Submitting promotion form, isEditMode:', isEditMode);
            const saveButton = document.getElementById('savePromotionBtn');
            const originalText = saveButton.textContent;
            saveButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Đang lưu...';
            saveButton.disabled = true;

            try {
                const ngayBatDau = document.getElementById('ngayBatDau').value;
                const hsd = document.getElementById('hsd').value;

                if (!ngayBatDau || !hsd) {
                    throw new Error('Vui lòng chọn ngày bắt đầu và ngày hết hạn');
                }

                const ngayBatDauDate = new Date(ngayBatDau);
                const hsdDate = new Date(hsd);

                if (isNaN(ngayBatDauDate.getTime()) || isNaN(hsdDate.getTime())) {
                    throw new Error('Ngày bắt đầu hoặc ngày hết hạn không hợp lệ');
                }

                const formData = new FormData();
                formData.append('ma_KM', document.getElementById('ma_KM').value || document.getElementById('ma_KM_input').value);
                formData.append('noiDung', document.getElementById('noiDung').value);
                formData.append('ngayBatDau', ngayBatDau);
                formData.append('hsd', hsd);
                formData.append('chietKhau', parseFloat(document.getElementById('chietKhau').value) || 0);
                formData.append('loaiChietKhau', document.getElementById('loaiChietKhau').value);
                formData.append('soDemToiThieu', parseInt(document.getElementById('soDemToiThieu').value) || '');
                formData.append('soNgayDatTruoc', parseInt(document.getElementById('soNgayDatTruoc').value) || '');
                formData.append('soLuong', parseInt(document.getElementById('soLuong').value) || 0);
                formData.append('chiApDungChoKhachMoi', document.getElementById('chiApDungChoKhachMoi').checked);
                const hinhAnhFile = document.getElementById('hinhAnhFile').files[0];
                if (hinhAnhFile) {
                    formData.append('HinhAnhFile', hinhAnhFile);
                }

                // Debug: Log form data
                console.log('Debug: FormData contents:');
                for (let [key, value] of formData.entries()) {
                    console.log(`  ${key}:`, value);
                }

                const csrfToken = getCsrfToken();
                if (!csrfToken) {
                    throw new Error('CSRF token not found');
                }

                const url = isEditMode ? '/Admin/Promotion/Update' : '/Admin/Promotion/Create';
                console.log('Debug: Sending request to:', url);
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'X-CSRF-TOKEN': csrfToken,
                        'RequestVerificationToken': csrfToken
                    },
                    body: formData
                });

                const responseText = await response.text();
                let data;
                try {
                    data = responseText ? JSON.parse(responseText) : {};
                    console.log('Debug: Server response:', data);
                } catch (e) {
                    console.error('Debug: Invalid JSON response:', responseText);
                    throw new Error('Phản hồi từ server không hợp lệ');
                }

                if (!response.ok) {
                    console.error('Debug: Server responded with status:', response.status, 'Response:', data);
                    throw new Error(data.message || `Lỗi HTTP! Mã: ${response.status}`);
                }

                if (data.success) {
                    console.log('Debug: Promotion saved successfully:', data.message);
                    showToast(data.message || 'Lưu khuyến mãi thành công', true);
                    closeModal('createEditModal');
                    loadPromotions();
                } else {
                    console.error('Debug: Failed to save promotion:', data.message);
                    showToast(data.message || 'Không thể lưu khuyến mãi', false);
                }
            } catch (error) {
                console.error('Debug: Error saving promotion:', error);
                showToast('Lỗi khi lưu khuyến mãi: ' + error.message, false);
            } finally {
                saveButton.textContent = originalText;
                saveButton.disabled = false;
                console.log('Debug: Form submission completed');
            }
        });

        // Confirm delete promotion
        function confirmDeletePromotion(ma_KM) {
            currentPromotionId = decodeURIComponent(ma_KM);
            if (!currentPromotionId) {
                showToast('Mã khuyến mãi không hợp lệ', false);
                return;
            }
            openModal('deleteModal');
        }

        // Delete promotion
        async function deletePromotion() {
            if (!currentPromotionId) {
                showToast('Mã khuyến mãi không hợp lệ', false);
                return;
            }

            const deleteButton = document.querySelector('#deleteModal button.bg-red-600');
            const originalText = deleteButton.textContent;
            deleteButton.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Đang xóa...';
            deleteButton.disabled = true;

            try {
                const csrfToken = getCsrfToken();
                if (!csrfToken) {
                    throw new Error('CSRF token not found');
                }

                const response = await fetch('/Admin/Promotion/DeleteConfirmed', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-CSRF-TOKEN': csrfToken,
                        'RequestVerificationToken': csrfToken
                    },
                    body: JSON.stringify(currentPromotionId)
                });

                const responseText = await response.text();
                let data;
                try {
                    data = responseText ? JSON.parse(responseText) : {};
                } catch (e) {
                    console.error('Invalid JSON response:', responseText);
                    throw new Error('Phản hồi từ server không hợp lệ');
                }

                if (!response.ok) {
                    console.error('Server responded with status:', response.status, 'Response:', data);
                    throw new Error(data.message || `HTTP error! Status: ${response.status}`);
                }

                if (data.success) {
                    showToast(data.message || 'Xóa khuyến mãi thành công', true);
                    closeModal('deleteModal');
                    loadPromotions();
                } else {
                    showToast(data.message || 'Không thể xóa khuyến mãi', false);
                }
            } catch (error) {
                console.error('Error deleting promotion:', error);
                showToast('Lỗi khi xóa khuyến mãi: ' + error.message, false);
            } finally {
                deleteButton.textContent = originalText;
                deleteButton.disabled = false;
            }
        }

        // Load homestays for filter
        async function loadHomestays() {
            try {
                const response = await fetch('/Admin/Homestay/GetHomestays', {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('GetHomestays Error Response:', errorText);
                    throw new Error(`HTTP error! Status: ${response.status}, Response: ${errorText}`);
                }

                const data = await response.json();
                if (data.success && data.data) {
                    allHomestays = data.data;
                    const select = document.getElementById('homestayFilter');
                    select.innerHTML = '<option value="">Tất cả homestay</option>' +
                        data.data.map(h => `<option value="${h.idHomestay}">${h.tenHomestay}</option>`).join('');
                } else {
                    showToast(data.message || 'Không thể tải danh sách homestay', false);
                }
            } catch (error) {
                console.error('Error loading homestays:', error);
                showToast('Lỗi khi tải danh sách homestay', false);
            }
        }

        // Initialize the page
        document.addEventListener('DOMContentLoaded', () => {
            flatpickr('#dateRangePicker', {
                mode: 'range',
                dateFormat: 'Y-m-d',
                altInput: true,
                altFormat: 'd/m/Y',
                allowInput: true,
                locale: {
                    rangeSeparator: ' to '
                },
                onChange: function(selectedDates, dateStr) {
                    if (selectedDates.length === 2) {
                        currentPage = 1;
                        loadPromotions();
                    }
                }
            });

            document.getElementById('searchInput').addEventListener('input', () => {
                currentPage = 1;
                loadPromotions();
            });

            document.getElementById('statusFilter').addEventListener('change', () => {
                currentPage = 1;
                loadPromotions();
            });

            document.getElementById('homestayFilter').addEventListener('change', () => {
                currentPage = 1;
                loadPromotions();
            });

            document.getElementById('tryAgainBtn').addEventListener('click', loadPromotions);

            // Initial load
            loadPromotions();
            loadHomestays();
        });
    </script>
}
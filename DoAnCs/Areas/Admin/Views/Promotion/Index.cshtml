            document.getElementById('ma_KM_input').disabled = true;

            try {
                console.log('Debug: Fetching promotion data for editing');
                const response = await fetch(`/Admin/Promotion/GetPromotion?id=${currentPromotionId}`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('GetPromotion for Edit Error Response:', errorText);
                    throw new Error(`HTTP error! Status: ${response.status}, Response: ${errorText}`);
                }

                const data = await response.json();
                console.log('Debug: Received promotion data for edit:', data);
                if (data.success) {
                    document.getElementById('ma_KM').value = data.maKM || '';

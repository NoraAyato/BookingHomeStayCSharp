                    flatpickr('#hsd', {
                        dateFormat: 'Y-m-d',
                        altInput: true,
                        altFormat: 'd/m/Y',
                        allowInput: true,
                        minDate: data.ngayBatDau?.split('T')[0] || 'today'
                    });

                    openModal('createEditModal');
                    console.log('Debug: Edit modal initialized with promotion data and flatpickr');
                } else {
                    console.error('Debug: Failed to load promotion data:', data.message);
                    showToast(data.message || 'Không thể tải thông tin khuyến mãi', false);

                `;
                document.getElementById('addRoleModalContent').innerHTML = modalContent;
                document.getElementById('addRoleModal').classList.remove('hidden');
            } else {
                showToast('error', userResult.message || 'Không thể tải dữ liệu vai trò.');
            }
        }

        async function openCreateRoleModal() {
            let rolesList = '';
            if (roleCache.length > 0) {
                rolesList = `
                    <div class="mt-6">
                        <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3 flex items-center">
                            <i class="fas fa-list-ul mr-2 text-primary-500"></i> Danh sách vai trò hiện có
                        </h4>
                        <ul class="border border-gray-200 dark:border-gray-600 rounded-lg divide-y divide-gray-200 dark:divide-gray-600">
                            ${roleCache.map(role => `
                                <li class="flex items-center justify-between px-4 py-3 hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors duration-200">
                                    <span class="text-sm font-medium text-gray-900 dark:text-gray-200">${role.name}</span>
                                    <button onclick="openDeleteRoleModal('${role.id}')" class="text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition-colors duration-200">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </li>
                            `).join('')}
                        </ul>
                    </div>
                `;
            } else {
                rolesList = '<div class="mt-6 bg-gray-50 dark:bg-gray-700 rounded-lg p-4 text-center"><p class="text-sm text-gray-500 dark:text-gray-400">Chưa có vai trò nào trong hệ thống.</p></div>';
            }

            const modalContent = `
                <div class="bg-white dark:bg-gray-800 px-6 pt-6 pb-4 sm:p-6 sm:pb-4">
                    <div class="sm:flex sm:items-start">
                        <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                            <h3 class="text-xl leading-6 font-bold text-gray-900 dark:text-gray-200" id="modal-title">
                                <i class="fas fa-plus-circle text-primary-500 mr-2"></i> Tạo Vai trò Mới
                            </h3>
                            <div class="mt-4">
                                <form id="createRoleForm" class="space-y-5">
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Tên vai trò</label>
                                        <input name="roleName" class="block w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg focus:ring-primary-500 focus:border-primary-500 sm:text-sm dark:bg-gray-700 dark:text-gray-200 transition duration-200" required />
                                    </div>
                                </form>
                                ${rolesList}
                            </div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 dark:bg-gray-700 px-6 py-4 sm:px-6 sm:flex sm:flex-row-reverse">
                    <button onclick="submitCreateRole()" class="w-full inline-flex justify-center rounded-lg border border-transparent shadow-sm px-5 py-2.5 bg-primary-600 text-base font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:ml-3 sm:w-auto sm:text-sm transition-colors duration-200">
                        <i class="fas fa-save mr-2"></i> Tạo vai trò
                    </button>
                    <button onclick="closeCreateRoleModal()" class="mt-3 w-full inline-flex justify-center rounded-lg border border-gray-300 dark:border-gray-600 shadow-sm px-5 py-2.5 bg-white dark:bg-gray-700 text-base font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm transition-colors duration-200">
                        <i class="fas fa-times mr-2"></i> Hủy bỏ
                    </button>
                </div>
            `;
            document.getElementById('createRoleModalContent').innerHTML = modalContent;
            document.getElementById('createRoleModal').classList.remove('hidden');
        }

        function openDeleteModal(id) {
            currentUserId = id;
            document.getElementById('deleteModal').classList.remove('hidden');
        }

        function openDeleteRoleModal(roleId) {
            const role = roleCache.find(r => r.id === roleId);
            if (!role) {
                showToast('error', 'Không tìm thấy vai trò trong hệ thống.');
                return;
            }
            currentRoleId = roleId;
            document.getElementById('deleteRoleName').textContent = role.name;
            document.getElementById('deleteRoleModal').classList.remove('hidden');
        }

        function closeDeleteRoleModal() {
            document.getElementById('deleteRoleModal').classList.add('hidden');
            currentRoleId = null;
            document.getElementById('deleteRoleName').textContent = '';
        }

        function closeUserModal() {
            document.getElementById('userModal').classList.add('hidden');
            document.getElementById('userModalContent').innerHTML = '';
        }

        function closeDetailsModal() {
            document.getElementById('detailsModal').classList.add('hidden');
            document.getElementById('detailsModalContent').innerHTML = '';
        }

        function closeAddRoleModal() {
            document.getElementById('addRoleModal').classList.add('hidden');
            document.getElementById('addRoleModalContent').innerHTML = '';
        }

        function closeCreateRoleModal() {
            document.getElementById('createRoleModal').classList.add('hidden');
            document.getElementById('createRoleModalContent').innerHTML = '';
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.add('hidden');
            currentUserId = null;
        }

        // Validation function for Add User Form
        function validateAddUserForm(formData) {
            let isValid = true;
            const email = formData.get('email');
            const password = formData.get('password');
            const fullName = formData.get('fullName');
            const dateOfBirth = formData.get('dateOfBirth');
            const profilePicture = formData.get('profilePicture');
            const trangThai = formData.get('trangThai');

            // Reset error messages
            document.querySelectorAll('#addUserForm .error-message').forEach(error => error.classList.add('hidden'));

            // Validate Email
            const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            if (!email) {
                document.getElementById('email-error').textContent = 'Email là bắt buộc.';
                document.getElementById('email-error').classList.remove('hidden');
                isValid = false;
            } else if (!emailRegex.test(email)) {
                document.getElementById('email-error').textContent = 'Email không đúng định dạng.';
                document.getElementById('email-error').classList.remove('hidden');
                isValid = false;
            }

            // Validate Password
            if (!password) {
                document.getElementById('password-error').textContent = 'Mật khẩu là bắt buộc.';
                document.getElementById('password-error').classList.remove('hidden');
                isValid = false;
            } else if (password.length < 6) {
                document.getElementById('password-error').textContent = 'Mật khẩu phải có ít nhất 6 ký tự.';
                document.getElementById('password-error').classList.remove('hidden');
                isValid = false;
            }

            // Validate Full Name
            if (!fullName) {
                document.getElementById('fullName-error').textContent = 'Họ và tên là bắt buộc.';
                document.getElementById('fullName-error').classList.remove('hidden');
                isValid = false;
            }

            // Validate Date of Birth
            if (dateOfBirth) {
                const dob = new Date(dateOfBirth);
                const today = new Date();
                if (dob > today) {
                    document.getElementById('dateOfBirth-error').textContent = 'Ngày sinh không được lớn hơn ngày hiện tại.';
                    document.getElementById('dateOfBirth-error').classList.remove('hidden');
                    isValid = false;
                }
            }

            // Validate Profile Picture
            if (profilePicture && profilePicture.size > 0) {
                const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg'];
                if (!validImageTypes.includes(profilePicture.type)) {
                    document.getElementById('profilePicture-error').textContent = 'Ảnh đại diện phải là file JPG, PNG hoặc JPEG.';
                    document.getElementById('profilePicture-error').classList.remove('hidden');
                    isValid = false;
                }
            }

            // Validate Trang Thai
            const validStatuses = ['Hoạt động', 'Khóa', 'Đang chờ duyệt', 'Đã xóa'];
            if (!trangThai || !validStatuses.includes(trangThai)) {
                document.getElementById('trangThai-error').textContent = 'Vui lòng chọn trạng thái hợp lệ.';
                document.getElementById('trangThai-error').classList.remove('hidden');
                isValid = false;
            }

            return isValid;
        }
        const changedFields = new Set();

        document.querySelectorAll('#editUserForm input, #editUserForm select, #editUserForm textarea').forEach(el => {
            el.addEventListener('change', () => {
                changedFields.add(el.name);
            });
        });

        // Validation function for Edit User Form
        function validateEditUserForm(formData) {
            let isValid = true;

            const fullName = formData.get('fullName');
            const dateOfBirth = formData.get('dateOfBirth');
            const profilePicture = formData.get('profilePicture');
            const trangThai = formData.get('trangThai');

            // Reset error messages
            document.querySelectorAll('#editUserForm .error-message').forEach(error => error.classList.add('hidden'));

           
            if (changedFields.has('fullName') && !fullName.trim()) {
                document.getElementById('fullName-error').textContent = 'Họ và tên là bắt buộc.';
                document.getElementById('fullName-error').classList.remove('hidden');
                isValid = false;
            }

            if (changedFields.has('dateOfBirth') && dateOfBirth) {
                const dob = new Date(dateOfBirth);
                const today = new Date();
                if (dob > today) {
                    document.getElementById('dateOfBirth-error').textContent = 'Ngày sinh không được lớn hơn ngày hiện tại.';
                    document.getElementById('dateOfBirth-error').classList.remove('hidden');
                    isValid = false;
                }
            }

            if (changedFields.has('profilePicture') && profilePicture && profilePicture.size > 0) {
                const validImageTypes = ['image/jpeg', 'image/png', 'image/jpg'];
                if (!validImageTypes.includes(profilePicture.type)) {
                    document.getElementById('profilePicture-error').textContent = 'Ảnh đại diện phải là file JPG, PNG hoặc JPEG.';
                    document.getElementById('profilePicture-error').classList.remove('hidden');
                    isValid = false;
                }
            }

            if (changedFields.has('trangThai') && (!trangThai || !['Hoạt động', 'Khóa', 'Đang chờ duyệt', 'Đã xóa'].includes(trangThai))) {
                document.getElementById('trangThai-error').textContent = 'Vui lòng chọn trạng thái hợp lệ.';
                document.getElementById('trangThai-error').classList.remove('hidden');
                isValid = false;
            }

            return isValid;
        }


        async function submitAddUser() {
            const form = document.getElementById('addUserForm');
            const formData = new FormData(form);

            // Validate form before submission
            if (!validateAddUserForm(formData)) {
                return;
            }

            const response = await fetch('/Admin/User/Create', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                userCache = []; // Reset cache to force reload
                totalRecords++;
                totalPages = Math.ceil(totalRecords / pageSize);
                showToast('success', result.message);
                closeUserModal();
                loadUsersWithCurrentFilters();
            } else {
                showToast('error', result.message + (result.errors ? '<br>' + result.errors.join('<br>') : ''));
            }
        }

        async function submitEditUser() {
            const form = document.getElementById('editUserForm');
            const formData = new FormData(form);

            // Validate form before submission
            if (!validateEditUserForm(formData)) {
                return;
            }

            const response = await fetch('/Admin/User/Update', {
                method: 'POST',
                body: formData
            });
            const result = await response.json();

            if (result.success) {
                userCache = []; // Reset cache to force reload
                showToast('success', result.message);
                closeUserModal();
                loadUsersWithCurrentFilters();
            } else {
                showToast('error', result.message + (result.errors ? '<br>' + result.errors.join('<br>') : ''));
            }
        }

        async function submitAddRole() {
            const form = document.getElementById('addRoleForm');
            const formData = new FormData(form);
            const data = {
                userId: currentUserId,
                roleName: formData.get('roleName')
            };

            const response = await fetch('/Admin/User/AddRole', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();

            if (result.success) {
                showToast('success', result.message);
                closeAddRoleModal();
                closeDetailsModal();
            } else {
                showToast('error', result.message + (result.errors ? '<br>' + result.errors.join('<br>') : ''));
            }
        }

        async function submitCreateRole() {
            const form = document.getElementById('createRoleForm');
            const formData = new FormData(form);
            const data = {
                roleName: formData.get('roleName')
            };

            const response = await fetch('/Admin/User/CreateRole', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            const result = await response.json();

            if (result.success) {
                roleCache.push(result.data);
                showToast('success', result.message);
                closeCreateRoleModal();
                openCreateRoleModal();
            } else {
                showToast('error', result.message + (result.errors ? '<br>' + result.errors.join('<br>') : ''));
            }
        }

        async function deleteRole(roleId) {
            openDeleteRoleModal(roleId);
        }

        async function confirmDeleteRole() {
            if (!currentRoleId) {
                showToast('error', 'Không có vai trò nào được chọn để xóa.');
                closeDeleteRoleModal();
                return;
            }

            try {
                const response = await fetch(`/Admin/User/DeleteRole/${currentRoleId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });

                const result = await response.json();

                if (result.success) {
                    roleCache = roleCache.filter(role => role.id !== currentRoleId);
                    showToast('success', result.message || 'Xóa vai trò thành công');
                    closeDeleteRoleModal();
                    closeCreateRoleModal();
                    openCreateRoleModal();
                } else {
                    showToast('error', result.message || 'Xóa vai trò thất bại');
                }
            } catch (error) {
                showToast('error', 'Đã xảy ra lỗi khi xóa vai trò. Vui lòng thử lại.');
                console.error(error);
            }
        }

        async function confirmDelete() {
            const response = await fetch(`/Admin/User/Delete/${currentUserId}`, {
                method: 'POST'
            });
            const result = await response.json();

            if (result.success) {
                userCache = []; // Reset cache to force reload
                showToast('success', result.message);
                closeDeleteModal();
                loadUsersWithCurrentFilters();
            } else {
                showToast('error', result.message + (result.errors ? '<br>' + result.errors.join('<br>') : ''));
            }
        }

        function showToast(type, message) {
            const toast = document.createElement('div');
            toast.className = `fixed top-4 right-4 px-5 py-3 rounded-lg shadow-lg text-white flex items-start ${
                type === 'success' ? 'bg-green-500' : 'bg-red-500'
            } z-50 max-w-md transition-all duration-300 transform translate-x-0 opacity-100`;
            toast.innerHTML = `
                <div class="flex-shrink-0 pt-0.5">
                    <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} text-lg"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm font-medium">${message}</p>
                </div>
                <button onclick="this.parentElement.remove()" class="ml-4 -mr-1.5 -mt-0.5 flex-shrink-0 p-1 rounded-full hover:bg-opacity-30 focus:outline-none focus:ring-2 focus:ring-white">
                    <span class="sr-only">Đóng</span>
                    <i class="fas fa-times h-4 w-4"></i>
                </button>
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-x-full');
                setTimeout(() => toast.remove(), 300);
            }, 5000);
        }
    </script>
}
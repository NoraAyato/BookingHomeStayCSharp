@section Scripts {
    <script>
        // Tất cả JavaScript gốc giữ nguyên không thay đổi
        let currentPage = 1;
        let pageSize = 6;
        let totalPages = 1;
        let currentUserId = null;
        let currentRoleId = null;
        let searchTimeout = null;
        let userCache = [];
        let roleCache = [];
        let totalRecords = 0;

        // Load users on page load
        document.addEventListener('DOMContentLoaded', () => {
            loadInitialData();
            setupEventListeners();
        });

        function setupEventListeners() {
            document.getElementById('searchInput').addEventListener('input', () => {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => {
                    currentPage = 1;
                    userCache = []; // Reset cache when search changes
                    loadUsersWithCurrentFilters();
                }, 500);
            });
            document.getElementById('statusFilter').addEventListener('change', () => {
                currentPage = 1;
                userCache = []; // Reset cache when filter changes
                loadUsersWithCurrentFilters();
            });
            document.getElementById('sortBy').addEventListener('change', () => {
                currentPage = 1;
                renderUsersFromCache();
            });
            document.getElementById('prevPage').addEventListener('click', () => {
                if (currentPage > 1) {
                    currentPage--;
                    renderUsersFromCache();
                }
            });
            document.getElementById('nextPage').addEventListener('click', () => {
                if (currentPage < totalPages) {
                    currentPage++;
                    renderUsersFromCache();
                }
            });
        }

        async function loadInitialData() {
            const userGrid = document.getElementById('userGrid');
            userGrid.innerHTML = '';
            document.getElementById('loadingState').classList.remove('hidden');
            document.getElementById('emptyState').classList.add('hidden');

            await loadUsersWithCurrentFilters();

            if (roleCache.length === 0) {
                const rolesResponse = await fetch('/Admin/User/GetRoles');
                const rolesResult = await rolesResponse.json();
                if (rolesResult.success) {
                    roleCache = rolesResult.data;
                } else {
                    console.error('Failed to load roles:', rolesResult.message);
                }
            }
        }

        async function loadUsersWithCurrentFilters() {
            const searchQuery = document.getElementById('searchInput').value;
            const statusFilter = document.getElementById('statusFilter').value;
            const cacheSize = pageSize * 3; // 18 bản ghi

            document.getElementById('loadingState').classList.remove('hidden');
            document.getElementById('emptyState').classList.add('hidden');

            try {
                const response = await fetch(`/Admin/User/GetUsers?searchQuery=${encodeURIComponent(searchQuery)}&statusFilter=${statusFilter}&pageNumber=1&pageSize=${cacheSize}`);
                if (!response.ok) {
                    showToast('error', 'Không thể tải danh sách người dùng. Vui lòng thử lại sau.');
                    document.getElementById('loadingState').classList.add('hidden');
                    document.getElementById('emptyState').classList.remove('hidden');
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    userCache = result.data || [];
                    totalRecords = result.totalRecords || 0;
                    totalPages = Math.ceil(totalRecords / pageSize);
                    renderUsersFromCache();
                } else {
                    showToast('error', result.message || 'Không có dữ liệu để hiển thị.');
                    document.getElementById('loadingState').classList.add('hidden');
                    document.getElementById('emptyState').classList.remove('hidden');
                }
            } catch (error) {
                console.error('Error loading users:', error);
                showToast('error', 'Đã xảy ra lỗi khi tải dữ liệu. Vui lòng thử lại.');
                document.getElementById('loadingState').classList.add('hidden');
                document.getElementById('emptyState').classList.remove('hidden');
            }
        }

        async function loadMoreUsers(pageNumber) {
            const cacheSize = pageSize * 3;
            const startPage = Math.max(1, pageNumber - 1);
            const searchQuery = document.getElementById('searchInput').value;
            const statusFilter = document.getElementById('statusFilter').value;

            try {
                const response = await fetch(`/Admin/User/GetUsers?searchQuery=${encodeURIComponent(searchQuery)}&statusFilter=${statusFilter}&pageNumber=${startPage}&pageSize=${cacheSize}`);
                const result = await response.json();
                if (result.success) {
                    userCache = result.data || [];
                    totalRecords = result.totalRecords || 0;
                    totalPages = Math.ceil(totalRecords / pageSize);
                    console.log('Loaded more users:', userCache); // Debug log
                    renderUsersFromCache();
                } else {
                    showToast('error', result.message || 'Không thể tải thêm dữ liệu.');
                }
            } catch (error) {
                console.error('Error loading more users:', error);
                showToast('error', 'Đã xảy ra lỗi khi tải thêm dữ liệu.');
            }
        }

        function renderUsersFromCache() {
            const searchQuery = document.getElementById('searchInput').value.toLowerCase();
            const statusFilter = document.getElementById('statusFilter').value;
            const sortBy = document.getElementById('sortBy').value;

            // Lọc dữ liệu từ userCache
            let filteredUsers = userCache.filter(user => {
                const matchesSearch = user.fullName.toLowerCase().includes(searchQuery) || user.email.toLowerCase().includes(searchQuery);
                const matchesStatus = statusFilter === 'all' || user.trangThai === statusFilter;
                return matchesSearch && matchesStatus;
            });

            if (sortBy === 'newest') {
                filteredUsers.sort((a, b) => new Date(b.ngayTao) - new Date(a.ngayTao));
            } else if (sortBy === 'oldest') {
                filteredUsers.sort((a, b) => new Date(a.ngayTao) - new Date(b.ngayTao));
            }

            const startIndex = (currentPage - 1) * pageSize;
            const paginatedUsers = filteredUsers.slice(startIndex, startIndex + pageSize);

            // Kiểm tra và tải thêm nếu cần
            if (startIndex >= userCache.length && currentPage <= totalPages) {
                loadMoreUsers(currentPage);
                return; // Chờ load xong để render lại
            }

            document.getElementById('totalUsers').textContent = totalRecords;
            document.getElementById('totalResults').textContent = totalRecords;

            const startRecord = startIndex + 1;
            const endRecord = Math.min(startIndex + pageSize, totalRecords);
            document.getElementById('startRecord').textContent = startRecord;
            document.getElementById('endRecord').textContent = endRecord;

            document.getElementById('prevPage').disabled = currentPage === 1;
            document.getElementById('nextPage').disabled = currentPage === totalPages;

            renderPageNumbers();
            renderUsers(paginatedUsers);
        }

        function renderPageNumbers() {
            const pageNumbers = document.getElementById('pageNumbers');
            pageNumbers.innerHTML = '';

            const maxPagesToShow = 5;
            let startPage = Math.max(1, currentPage - Math.floor(maxPagesToShow / 2));
            let endPage = Math.min(totalPages, startPage + maxPagesToShow - 1);

            if (endPage - startPage + 1 < maxPagesToShow) {
                startPage = Math.max(1, endPage - maxPagesToShow + 1);
            }

            for (let i = startPage; i <= endPage; i++) {
                const pageButton = `

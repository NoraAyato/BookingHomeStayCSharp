        async function openAddRoleModal(id) {
            currentUserId = id;

            const userResponse = await fetch(`/Admin/User/Details/${id}`);
            const userResult = await userResponse.json();

            if (userResult.success && roleCache.length > 0) {
                const userRoles = userResult.data.roles || [];
                const availableRoles = roleCache.filter(role => !userRoles.includes(role.name));

                if (availableRoles.length === 0) {
                    showToast('error', 'Người dùng đã có tất cả vai trò hiện có.');
                    return;
                }

                const roleOptions = availableRoles.map(role => `<option value="${role.name}">${role.name}</option>`).join('');

                const modalContent = `
                    <div class="bg-white dark:bg-gray-800 px-6 pt-6 pb-4 sm:p-6 sm:pb-4">
                        <div class="sm:flex sm:items-start">
                            <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                                <h3 class="text-xl leading-6 font-bold text-gray-900 dark:text-gray-200" id="modal-title">

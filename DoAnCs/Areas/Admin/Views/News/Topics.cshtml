@model IEnumerable<DoAnCs.Models.ChuDe>
@{
    ViewData["Title"] = "Quản lý Chủ đề";
    var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
}

<!-- Main Content -->
<main class="flex-1 overflow-y-auto px-4 py-6 bg-gray-50 dark:bg-gray-900">
    <div class="max-w-7xl mx-auto">
        <!-- Header Section -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6">
            <div>
                <h1 class="text-2xl md:text-3xl font-bold text-gray-800 dark:text-gray-100">Quản lý Chủ đề</h1>
                <p class="text-gray-600 dark:text-gray-400 mt-1 text-sm md:text-base">
                    Tổng số chủ đề: <span id="totalTopics" class="font-semibold text-primary-600 dark:text-primary-400">@Model.Count()</span>
                </p>
            </div>
            <div class="flex gap-2">
                <a asp-area="Admin" asp-controller="News" asp-action="Index"
                   class="inline-flex items-center gap-2 bg-secondary-600 hover:bg-secondary-700 text-white px-4 py-2.5 rounded-lg shadow-md transition-all duration-300 hover:shadow-lg text-sm md:text-base">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M9.707 16.707a1 1 0 01-1.414 0l-6-6a1 1 0 010-1.414l6-6a1 1 0 011.414 1.414L5.414 9H17a1 1 0 110 2H5.414l4.293 4.293a1 1 0 010 1.414z" clip-rule="evenodd" />
                    </svg>
                    Quay lại Tin tức
                </a>
                <button onclick="openAddTopicModal()"
                        class="inline-flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-4 py-2.5 rounded-lg shadow-md transition-all duration-300 hover:shadow-lg text-sm md:text-base">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Thêm chủ đề mới
                </button>
            </div>
        </div>

        <!-- Topics Table -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                    <thead class="bg-gray-50 dark:bg-gray-700">
                        <tr>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                Tên chủ đề
                            </th>
                            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                Số bài viết
                            </th>
                            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">
                                Thao tác
                            </th>
                        </tr>
                    </thead>
                    <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                        @foreach (var topic in Model)
                        {
                            <tr class="hover:bg-gray-50 dark:hover:bg-gray-7
                            00">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm font-medium text-gray-900 dark:text-gray-100">@topic.TenChuDe</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="text-sm text-gray-500 dark:text-gray-400">@topic.TinTucs?.Count</div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                    <button onclick="openEditTopicModal('@topic.ID_ChuDe')" class="text-primary-600 hover:text-primary-900 dark:text-primary-400 dark:hover:text-primary-300 mr-3">Sửa</button>
                                    <button onclick="openDeleteTopicModal('@topic.ID_ChuDe')" class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300">Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="@(Model.Any() ? "hidden" : "") bg-white dark:bg-gray-800 rounded-xl p-8 text-center border border-gray-200 dark:border-gray-700 mt-6">
            <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
            <h3 class="mt-2 text-lg font-medium text-gray-900 dark:text-gray-100">Không có chủ đề nào</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Bắt đầu bằng cách thêm chủ đề mới.</p>
            <div class="mt-6">
                <button type="button" onclick="openAddTopicModal()"
                        class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-primary-600 hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500">
                    <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Thêm chủ đề mới
                </button>
            </div>
        </div>
    </div>
</main>

<!-- Add Topic Modal -->
<div id="addTopicModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" aria-modal="true" role="dialog">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full">
            <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900 sm:mx-0 sm:h-10 sm:w-10">
                        <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-100" id="modal-title">Thêm Chủ đề mới</h3>
                        <div class="mt-2 w-full">
                            <form id="addTopicForm" class="space-y-4">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên chủ đề *</label>
                                    <input type="text" id="add_TenChuDe" name="TenChuDe" required
                                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
                                    <span id="add_TenChuDe_Error" class="text-red-500 text-xs mt-1 hidden"></span>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" id="addTopicSubmit" onclick="submitAddTopicForm()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary-600 text-base font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:ml-3 sm:w-auto sm:text-sm" disabled>
                    Thêm chủ đề
                </button>
                <button type="button" onclick="closeAddTopicModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-600 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Edit Topic Modal -->
<div id="editTopicModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" aria-modal="true" role="dialog">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-md sm:w-full">
            <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900 sm:mx-0 sm:h-10 sm:w-10">
                        <svg class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                        </svg>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-100" id="modal-title">Chỉnh sửa Chủ đề</h3>
                        <div class="mt-2 w-full">
                            <form id="editTopicForm" class="space-y-4">
                                <input type="hidden" id="edit_ID_ChuDe" name="ID_ChuDe">
                                <div>
                                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên chủ đề *</label>
                                    <input type="text" id="edit_TenChuDe" name="TenChuDe" required
                                           class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-primary-500 focus:border-primary-500 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-100">
                                    <span id="edit_TenChuDe_Error" class="text-red-500 text-xs mt-1 hidden"></span>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" id="editTopicSubmit" onclick="submitEditTopicForm()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-primary-600 text-base font-medium text-white hover:bg-primary-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:ml-3 sm:w-auto sm:text-sm" disabled>
                    Lưu thay đổi
                </button>
                <button type="button" onclick="closeEditTopicModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-600 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Topic Modal -->
<div id="deleteTopicModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" aria-modal="true" role="dialog">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900 sm:mx-0 sm:h-10 sm:w-10">
                        <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-100" id="modal-title">Xác nhận xóa</h3>
                        <div class="mt-2">
                            <p id="deleteTopicMessage" class="text-sm text-gray-500 dark:text-gray-400">Bạn có chắc chắn muốn xóa chủ đề này? Tất cả bài viết thuộc chủ đề này sẽ không còn được phân loại.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="confirmDeleteTopic()" class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm">
                    Xác nhận xóa
                </button>
                <button type="button" onclick="closeDeleteTopicModal()" class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-600 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-primary-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="fixed top-4 right-4 z-50 hidden">
    <div class="flex items-center p-4 rounded-lg shadow-lg max-w-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
        <div id="toastIcon" class="mr-3"></div>
        <div id="toastMessage" class="text-sm font-medium text-gray-900 dark:text-gray-100"></div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentTopicId = '';

        // Hàm kiểm tra tên chủ đề có trùng không
        function checkTopicName(name, inputId, errorId, submitId, excludeId = '') {
            const trimmedName = name.trim();
            const $input = $(`#${inputId}`);
            const $error = $(`#${errorId}`);
            const $submit = $(`#${submitId}`);

            // Kiểm tra trường trống
            if (!trimmedName) {
                $input.addClass('border-red-500');
                $error.text('Tên chủ đề không được để trống').removeClass('hidden');
                $submit.prop('disabled', true);
                return;
            }

            // Kiểm tra độ dài tối đa (giả sử tối đa 100 ký tự)
            if (trimmedName.length > 100) {
                $input.addClass('border-red-500');
                $error.text('Tên chủ đề không được vượt quá 100 ký tự').removeClass('hidden');
                $submit.prop('disabled', true);
                return;
            }

            // Gửi AJAX để kiểm tra trùng tên
            $.ajax({
                url: '/Admin/News/CheckTopicName',
                type: 'GET',
                data: { name: trimmedName, excludeId: excludeId },
                success: function (response) {
                    if (response.exists) {
                        $input.addClass('border-red-500');
                        $error.text('Tên chủ đề đã tồn tại').removeClass('hidden');
                        $submit.prop('disabled', true);
                    } else {
                        $input.removeClass('border-red-500');
                        $error.addClass('hidden');
                        $submit.prop('disabled', false);
                    }
                },
                error: function () {
                    $input.addClass('border-red-500');
                    $error.text('Lỗi khi kiểm tra tên chủ đề').removeClass('hidden');
                    $submit.prop('disabled', true);
                }
            });
        }

        // Validate khi nhập vào trường tên chủ đề
        $('#add_TenChuDe').on('input', function () {
            checkTopicName($(this).val(), 'add_TenChuDe', 'add_TenChuDe_Error', 'addTopicSubmit');
        });

        $('#edit_TenChuDe').on('input', function () {
            checkTopicName($(this).val(), 'edit_TenChuDe', 'edit_TenChuDe_Error', 'editTopicSubmit', currentTopicId);
        });

        // Mở modal thêm chủ đề
        function openAddTopicModal() {
            $('#addTopicModal').removeClass('hidden');
            $('#add_TenChuDe').val('');
            $('#add_TenChuDe_Error').addClass('hidden');
            $('#add_TenChuDe').removeClass('border-red-500');
            $('#addTopicSubmit').prop('disabled', true);
        }

        // Đóng modal thêm chủ đề
        function closeAddTopicModal() {
            $('#addTopicModal').addClass('hidden');
        }

        // Mở modal sửa chủ đề
        function openEditTopicModal(id) {
            currentTopicId = id;
            fetch(`/Admin/News/GetTopic?id=${id}`)
                .then(response => response.json())
                .then(data => {
                    $('#edit_ID_ChuDe').val(data.idChuDe);
                    $('#edit_TenChuDe').val(data.tenChuDe);
                    $('#edit_TenChuDe_Error').addClass('hidden');
                    $('#edit_TenChuDe').removeClass('border-red-500');
                    $('#editTopicSubmit').prop('disabled', true);
                    $('#editTopicModal').removeClass('hidden');
                    // Kiểm tra tên chủ đề ngay khi mở modal
                    checkTopicName(data.tenChuDe, 'edit_TenChuDe', 'edit_TenChuDe_Error', 'editTopicSubmit', id);
                })
                .catch(error => {
                    showToast('error', 'Không thể tải thông tin chủ đề');
                    console.error(error);
                });
        }

        // Đóng modal sửa chủ đề
        function closeEditTopicModal() {
            $('#editTopicModal').addClass('hidden');
        }

        // Mở modal xóa chủ đề
        function openDeleteTopicModal(id) {
            currentTopicId = id;
            $.ajax({
                url: '/Admin/News/GetTopicNewsCount',
                type: 'GET',
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        const newsCount = response.newsCount;
                        const message = `Chủ đề này bao gồm ${newsCount} tin tức. Bạn có chắc chắn muốn xóa? Tất cả bài viết thuộc chủ đề này sẽ không còn được phân loại.`;
                        $('#deleteTopicMessage').text(message);
                        $('#deleteTopicModal').removeClass('hidden');
                    } else {
                        showToast('error', response.message || 'Không thể tải thông tin tin tức của chủ đề');
                    }
                },
                error: function () {
                    showToast('error', 'Lỗi khi tải thông tin tin tức của chủ đề');
                }
            });
        }

        // Đóng modal xóa chủ đề
        function closeDeleteTopicModal() {
            $('#deleteTopicModal').addClass('hidden');
        }

        // Gửi form thêm chủ đề
        function submitAddTopicForm() {
            const formData = {
                TenChuDe: $('#add_TenChuDe').val().trim()
            };

            const submitBtn = $('#addTopicSubmit');
            submitBtn.prop('disabled', true);
            submitBtn.html('<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang xử lý...');

            $.ajax({
                url: '/Admin/News/CreateTopic',
                type: 'POST',
                data: formData,
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        showToast('success', 'Thêm chủ đề thành công');
                        closeAddTopicModal();
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast('error', response.message || 'Có lỗi xảy ra');
                    }
                },
                error: function (xhr) {
                    showToast('error', 'Có lỗi xảy ra khi thêm chủ đề');
                    console.error(xhr.responseText);
                },
                complete: function() {
                    submitBtn.prop('disabled', false);
                    submitBtn.html('Thêm chủ đề');
                }
            });
        }

        // Gửi form sửa chủ đề
        function submitEditTopicForm() {
            const formData = {
                ID_ChuDe: $('#edit_ID_ChuDe').val(),
                TenChuDe: $('#edit_TenChuDe').val().trim()
            };

            const submitBtn = $('#editTopicSubmit');
            submitBtn.prop('disabled', true);
            submitBtn.html('<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang lưu...');

            $.ajax({
                url: '/Admin/News/UpdateTopic',
                type: 'POST',
                data: formData,
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        showToast('success', 'Cập nhật chủ đề thành công');
                        closeEditTopicModal();
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast('error', response.message || 'Có lỗi xảy ra');
                    }
                },
                error: function (xhr) {
                    showToast('error', 'Có lỗi xảy ra khi cập nhật');
                    console.error(xhr.responseText);
                },
                complete: function() {
                    submitBtn.prop('disabled', false);
                    submitBtn.html('Lưu thay đổi');
                }
            });
        }

        // Xác nhận xóa chủ đề
        function confirmDeleteTopic() {
            const submitBtn = $('#deleteTopicModal').find('button[type="button"]').first();
            submitBtn.prop('disabled', true);
            submitBtn.html('<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang xóa...');

            $.ajax({
                url: '/Admin/News/DeleteTopic',
                type: 'POST',
                data: { id: currentTopicId },
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                success: function (response) {
                    if (response.success) {
                        showToast('success', 'Xóa chủ đề thành công');
                        closeDeleteTopicModal();
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        showToast('error', response.message || 'Có lỗi xảy ra');
                        submitBtn.prop('disabled', false);
                        submitBtn.html('Xác nhận xóa');
                    }
                },
                error: function (xhr) {
                    showToast('error', 'Có lỗi xảy ra khi xóa chủ đề');
                    console.error(xhr.responseText);
                    submitBtn.prop('disabled', false);
                    submitBtn.html('Xác nhận xóa');
                }
            });
        }

        // Toast notification
        function showToast(type, message) {
            const toast = document.getElementById('toast');
            const toastIcon = document.getElementById('toastIcon');
            const toastMessage = document.getElementById('toastMessage');

            toast.className = `fixed top-4 right-4 z-50 flex items-center p-4 rounded-lg shadow-lg max-w-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700`;

            if (type === 'success') {
                toastIcon.innerHTML = '<svg class="w-6 h-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
            } else {
                toastIcon.innerHTML = '<svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>';
            }

            toastMessage.textContent = message;
            toast.classList.remove('hidden');

            setTimeout(() => {
                toast.classList.add('hidden');
            }, 3000);
        }
    </script>
}
@using DoAnCs.Models
@model IEnumerable<DichVu>
@{
    ViewData["Title"] = "Quản lý Dịch Vụ";
    var homestayId = ViewBag.HomestayId;
    var homestayName = ViewBag.HomestayName;
}

<!-- Main Content -->
<main class="flex-1 overflow-y-auto px-4 md:px-6 py-4 bg-gray-50 dark:bg-gray-900">
    <div class="bg-white dark:bg-gray-800 rounded-lg shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
        <!-- Header Section -->
        <div class="px-6 py-4 border-b border-gray-200 dark:border-gray-700">
            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h1 class="text-xl md:text-2xl font-bold text-gray-800 dark:text-gray-200">Quản lý Dịch Vụ - @homestayName</h1>
                    <p class="text-gray-600 dark:text-gray-400 mt-1 text-sm md:text-base">
                        Tổng số dịch vụ: <span class="font-semibold text-blue-600 dark:text-blue-400">@ViewBag.TotalDichVus</span>
                    </p>
                </div>
                <button onclick="showCreateModal()"
                        class="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white px-4 py-2.5 rounded-lg shadow-md transition-all duration-300 hover:shadow-lg text-sm md:text-base">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                    </svg>
                    Thêm dịch vụ mới
                </button>
            </div>
        </div>

        <!-- Service Table -->
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
                <thead class="bg-gray-50 dark:bg-gray-700">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Hình Ảnh</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Tên Dịch Vụ</th>
                        <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Đơn Giá</th>
                        <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Thao Tác</th>
                    </tr>
                </thead>
                <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors">
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (!string.IsNullOrEmpty(item.HinhAnh))
                                {
                                    <img src="@item.HinhAnh" alt="@item.Ten_DV" class="w-16 h-16 object-cover rounded-lg border border-gray-200 dark:border-gray-600">
                                }
                                else
                                {
                                    <span class="text-xs text-gray-500 dark:text-gray-400">Không có ảnh</span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm font-medium text-gray-900 dark:text-gray-200">@item.Ten_DV</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-500 dark:text-gray-400">@item.DonGia.ToString("N0") VNĐ</div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex justify-end gap-2">
                                    <button onclick="showEditModal('@item.Ma_DV')"
                                            class="p-2 text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-gray-700 rounded-lg hover:bg-blue-100 dark:hover:bg-gray-600 transition-colors">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>
                                    <button onclick="confirmDelete('@item.Ma_DV')"
                                            class="p-2 text-red-600 dark:text-red-400 bg-red-50 dark:bg-gray-700 rounded-lg hover:bg-red-100 dark:hover:bg-gray-600 transition-colors">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Empty State -->
        <div id="emptyState" class="@(Model.Any() ? "hidden" : "") bg-white dark:bg-gray-800 p-8 text-center border border-gray-200 dark:border-gray-700">
            <svg class="mx-auto h-12 w-12 text-gray-400 dark:text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
            <h3 class="mt-2 text-lg font-medium text-gray-900 dark:text-gray-200">Không tìm thấy dịch vụ nào</h3>
            <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Thử thay đổi tiêu chí tìm kiếm hoặc thêm dịch vụ mới.</p>
            <div class="mt-6">
                <button type="button" onclick="showCreateModal()"
                        class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                    <svg class="-ml-1 mr-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Thêm dịch vụ mới
                </button>
            </div>
        </div>

        <!-- Pagination -->
        <div class="bg-gray-50 dark:bg-gray-700 p-4 border-t border-gray-200 dark:border-gray-600">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <span class="text-xs md:text-sm text-gray-500 dark:text-gray-400">
                    Hiển thị <span class="font-medium">@((ViewBag.PageNumber - 1) * ViewBag.PageSize + 1)</span> đến
                    <span class="font-medium">@Math.Min(ViewBag.PageNumber * ViewBag.PageSize, ViewBag.TotalDichVus)</span> của
                    <span class="font-medium">@ViewBag.TotalDichVus</span> kết quả
                </span>
                <div class="flex items-center gap-1">
                    <a href="@Url.Action("Index", new { homestayId = ViewBag.HomestayId, pageNumber = ViewBag.PageNumber - 1, pageSize = ViewBag.PageSize })"
                       class="px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-600 hover:bg-gray-200 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200 transition-colors flex items-center text-sm @(ViewBag.PageNumber <= 1 ? "pointer-events-none opacity-50" : "")">
                        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                        </svg>
                        Trước
                    </a>
                    <div class="flex gap-1">
                        @for (int i = 1; i <= ViewBag.TotalPages; i++)
                        {
                            <a href="@Url.Action("Index", new { homestayId = ViewBag.HomestayId, pageNumber = i, pageSize = ViewBag.PageSize })"
                               class="px-3 py-1.5 rounded-lg text-sm @(i == ViewBag.PageNumber ? "bg-blue-600 text-white" : "bg-gray-100 dark:bg-gray-600 hover:bg-gray-200 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200")">@i</a>
                        }
                    </div>
                    <a href="@Url.Action("Index", new { homestayId = ViewBag.HomestayId, pageNumber = ViewBag.PageNumber + 1, pageSize = ViewBag.PageSize })"
                       class="px-3 py-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-500 text-gray-700 dark:text-gray-200 transition-colors flex items-center text-sm @(ViewBag.PageNumber >= ViewBag.TotalPages ? "pointer-events-none opacity-50" : "")">
                        Sau
                        <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Create/Edit Modal -->
<div id="dichVuModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" aria-modal="true" role="dialog">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-2xl sm:w-full">
            <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900 sm:mx-0 sm:h-10 sm:w-10">
                        <svg id="modalIcon" class="h-6 w-6 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                        </svg>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left w-full">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-200" id="modalTitle">Thêm Dịch Vụ Mới</h3>
                        <div class="mt-2 w-full">
                            <form id="dichVuForm" class="space-y-4" enctype="multipart/form-data">
                                <input type="hidden" id="Ma_DV" name="Ma_DV" />
                                <input type="hidden" name="ID_Homestay" value="@homestayId" />

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Tên Dịch Vụ *</label>
                                        <select id="Ten_DV" name="Ten_DV" required
                                                class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-200">
                                            <option value="">Chọn dịch vụ</option>
                                        </select>
                                    </div>

                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Đơn Giá (VNĐ) *</label>
                                        <input type="number" id="DonGia" name="DonGia" required
                                               class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-md shadow-sm focus:outline-none focus:ring-blue-500 focus:border-blue-500 text-sm bg-white dark:bg-gray-700 text-gray-900 dark:text-gray-200">
                                    </div>

                                    <div class="md:col-span-2">
                                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Hình Ảnh</label>
                                        <div class="flex items-center gap-2">
                                            <label class="cursor-pointer">
                                                <span class="inline-flex items-center px-3 py-2 border border-gray-300 dark:border-gray-600 shadow-sm text-sm leading-4 font-medium rounded-md text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                                                    <svg class="-ml-1 mr-2 h-5 w-5 text-gray-500 dark:text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" />
                                                    </svg>
                                                    Tải lên
                                                </span>
                                                <input type="file" id="HinhAnhFile" name="HinhAnhFile" accept="image/*" class="sr-only">
                                            </label>
                                            <span id="mainImageFileName" class="text-sm text-gray-500 dark:text-gray-400 truncate max-w-xs">Chưa chọn file</span>
                                        </div>
                                        <div id="mainImagePreview" class="mt-2 hidden">
                                            <p class="text-xs font-medium text-gray-700 dark:text-gray-300 mb-1">Ảnh hiện tại:</p>
                                            <img id="currentMainImage" class="h-24 w-24 object-cover rounded-md border border-gray-200 dark:border-gray-600">
                                        </div>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <button type="button" onclick="submitDichVuForm()" id="submitDichVuBtn"
                        class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-blue-600 text-base font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:ml-3 sm:w-auto sm:text-sm">
                    Lưu thay đổi
                </button>
                <button type="button" onclick="closeDichVuModal()"
                        class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-600 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 z-50 overflow-y-auto hidden" aria-labelledby="modal-title" aria-modal="true" role="dialog">
    <div class="flex items-end justify-center min-h-screen pt-4 px-4 pb-20 text-center sm:block sm:p-0">
        <!-- Background overlay -->
        <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>

        <!-- Modal panel -->
        <div class="inline-block align-bottom bg-white dark:bg-gray-800 rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full">
            <div class="bg-white dark:bg-gray-800 px-4 pt-5 pb-4 sm:p-6 sm:pb-4">
                <div class="sm:flex sm:items-start">
                    <div class="mx-auto flex-shrink-0 flex items-center justify-center h-12 w-12 rounded-full bg-red-100 dark:bg-red-900 sm:mx-0 sm:h-10 sm:w-10">
                        <svg class="h-6 w-6 text-red-600 dark:text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                        </svg>
                    </div>
                    <div class="mt-3 text-center sm:mt-0 sm:ml-4 sm:text-left">
                        <h3 class="text-lg leading-6 font-medium text-gray-900 dark:text-gray-200" id="modal-title">Xác nhận xóa</h3>
                        <div class="mt-2">
                            <p class="text-sm text-gray-500 dark:text-gray-400">Bạn có chắc chắn muốn xóa dịch vụ này? Tất cả dữ liệu liên quan sẽ bị xóa vĩnh viễn và không thể khôi phục.</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="bg-gray-50 dark:bg-gray-700 px-4 py-3 sm:px-6 sm:flex sm:flex-row-reverse">
                <form id="deleteForm" method="post" class="inline-flex">
                    <button type="submit"
                            class="w-full inline-flex justify-center rounded-md border border-transparent shadow-sm px-4 py-2 bg-red-600 text-base font-medium text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:ml-3 sm:w-auto sm:text-sm">
                        Xác nhận xóa
                    </button>
                </form>
                <button type="button" onclick="closeDeleteModal()"
                        class="mt-3 w-full inline-flex justify-center rounded-md border border-gray-300 dark:border-gray-600 shadow-sm px-4 py-2 bg-white dark:bg-gray-600 text-base font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-500 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 sm:mt-0 sm:ml-3 sm:w-auto sm:text-sm">
                    Hủy bỏ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Notification -->
<div id="toast" class="fixed top-4 right-4 z-50 hidden">
    <div class="flex items-center p-4 rounded-lg shadow-lg max-w-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700">
        <div id="toastIcon" class="mr-3"></div>
        <div id="toastMessage" class="text-sm font-medium text-gray-900 dark:text-gray-200"></div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script>
        $(document).ready(function () {
            if (@Model.Count() === 0) {
                $('#emptyState').removeClass('hidden');
                $('table').addClass('hidden');
            } else {
                $('#emptyState').addClass('hidden');
                $('table').removeClass('hidden');
            }
        });

        function showCreateModal() {
            $('#modalTitle').text('Thêm Dịch Vụ Mới');
            $('#modalIcon').html('<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />');
            $('#dichVuForm').attr('action', '@Url.Action("Create", "Service", new { area = "Host" })');
            $('#Ma_DV').val('');
            $('#dichVuForm')[0].reset();
            $('#mainImagePreview').addClass('hidden');
            $('#mainImageFileName').text('Chưa chọn file');

            const homestayId = '@homestayId';
            if (!homestayId) {
                showToast('error', 'Không tìm thấy ID Homestay');
                return;
            }
            $('#dichVuForm').find('input[name="ID_Homestay"]').val(homestayId);

            // Tải danh sách dịch vụ mẫu còn khả dụng
            fetch('@Url.Action("GetAvailableServiceTemplates", "Service", new { area = "Host" })?homestayId=' + homestayId)
                .then(response => response.json())
                .then(data => {
                    const select = $('#Ten_DV');
                    select.empty();
                    select.append('<option value="">Chọn dịch vụ</option>');
                    data.forEach(template => {
                        select.append(`<option value="${template}">${template}</option>`);
                    });
                    $('#dichVuModal').removeClass('hidden');
                })
                .catch(error => {
                    showToast('error', 'Không thể tải danh sách dịch vụ mẫu');
                    console.error(error);
                });
        }

        function showEditModal(maDV) {
            fetch('@Url.Action("GetDichVu", "Service", new { area = "Host" })?id=' + maDV)
                .then(response => response.json())
                .then(data => {
                    $('#modalTitle').text('Chỉnh Sửa Dịch Vụ');
                    $('#modalIcon').html('<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />');
                    $('#dichVuForm').attr('action', '@Url.Action("Update", "Service", new { area = "Host" })/' + maDV);

                    $('#Ma_DV').val(data.ma_DV);
                    $('#DonGia').val(data.donGia);

                    // Tải danh sách dịch vụ mẫu còn khả dụng, bao gồm tên dịch vụ hiện tại
                    fetch('@Url.Action("GetAvailableServiceTemplates", "Service", new { area = "Host" })?homestayId=' + data.id_Homestay + '&excludeMaDV=' + maDV)
                        .then(response => response.json())
                        .then(templates => {
                            const select = $('#Ten_DV');
                            select.empty();
                            select.append('<option value="">Chọn dịch vụ</option>');
                            templates.forEach(template => {
                                select.append(`<option value="${template}" ${template === data.ten_DV ? 'selected' : ''}>${template}</option>`);
                            });
                            // Thêm tên dịch vụ hiện tại nếu không có trong danh sách mẫu
                            if (!templates.includes(data.ten_DV)) {
                                select.append(`<option value="${data.ten_DV}" selected>${data.ten_DV}</option>`);
                            }
                            $('#dichVuModal').removeClass('hidden');
                        })
                        .catch(error => {
                            showToast('error', 'Không thể tải danh sách dịch vụ mẫu');
                            console.error(error);
                        });

                    if (data.hinhAnh) {
                        $('#currentMainImage').attr('src', data.hinhAnh);
                        $('#mainImagePreview').removeClass('hidden').show();
                        $('#mainImageFileName').text('Đã có ảnh');
                    } else {
                        $('#mainImagePreview').addClass('hidden');
                        $('#mainImageFileName').text('Chưa chọn file');
                    }
                })
                .catch(error => {
                    showToast('error', 'Không thể tải thông tin dịch vụ');
                    console.error(error);
                });
        }

        function closeDichVuModal() {
            $('#dichVuModal').addClass('hidden');
        }

        function confirmDelete(maDV) {
            $('#deleteForm').attr('action', '@Url.Action("DeleteConfirmed", "Service", new { area = "Host" })/' + maDV);
            $('#deleteModal').removeClass('hidden');
        }

        function closeDeleteModal() {
            $('#deleteModal').addClass('hidden');
        }

        $('#HinhAnhFile').change(function() {
            const fileName = this.files[0]?.name || 'Chưa chọn file';
            $('#mainImageFileName').text(fileName);

            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    $('#currentMainImage').attr('src', e.target.result);
                    $('#mainImagePreview').removeClass('hidden').show();
                }
                reader.readAsDataURL(this.files[0]);
            }
        });

        function submitDichVuForm() {
            const form = document.getElementById('dichVuForm');
            const formData = new FormData(form);
            const submitBtn = $('#submitDichVuBtn');

            submitBtn.prop('disabled', true);
            submitBtn.html('<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang xử lý...');

            $.ajax({
                url: $(form).attr('action'),
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function (response) {
                    if (response.success) {
                        showToast('success', response.message || 'Thao tác thành công');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        showToast('error', response.message || 'Có lỗi xảy ra');
                    }
                },
                error: function (xhr) {
                    showToast('error', 'Lỗi kết nối server');
                    console.error(xhr.responseText);
                },
                complete: function() {
                    submitBtn.prop('disabled', false);
                    submitBtn.html('Lưu thay đổi');
                }
            });
        }

        $('#deleteForm').submit(function(e) {
            e.preventDefault();
            const submitBtn = $(this).find('button[type="submit"]');
            submitBtn.prop('disabled', true);
            submitBtn.html('<svg class="animate-spin -ml-1 mr-2 h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Đang xử lý...');

            $.ajax({
                url: $(this).attr('action'),
                type: 'POST',
                success: function (response) {
                    if (response.success) {
                        showToast('success', response.message || 'Xóa thành công');
                        setTimeout(() => window.location.reload(), 1500);
                    } else {
                        showToast('error', response.message || 'Có lỗi xảy ra');
                    }
                },
                error: function (xhr) {
                    showToast('error', 'Lỗi kết nối server');
                    console.error(xhr.responseText);
                },
                complete: function() {
                    submitBtn.prop('disabled', false);
                    submitBtn.html('Xác nhận xóa');
                    closeDeleteModal();
                }
            });
        });

        function showToast(type, message) {
            const toast = document.getElementById('toast');
            const toastIcon = document.getElementById('toastIcon');
            const toastMessage = document.getElementById('toastMessage');

            toast.className = `fixed top-4 right-4 z-50 flex items-center p-4 rounded-lg shadow-lg max-w-xs bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700`;

            if (type === 'success') {
                toastIcon.innerHTML = '<svg class="w-6 h-6 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>';
            } else {
                toastIcon.innerHTML = '<svg class="w-6 h-6 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>';
            }

            toastMessage.innerHTML = message;
            toast.classList.remove('hidden');

            setTimeout(() => {
                toast.classList.add('hidden');
            }, 3000);
        }
    </script>
}
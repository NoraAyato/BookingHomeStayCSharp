@model DoAnCs.Models.ViewModels.SearchHomestayViewModel
@{
    ViewData["Title"] = "Kết quả tìm kiếm Homestay";
}

<!-- Header với thông tin tìm kiếm -->
<section class="relative bg-gradient-to-b from-rose-100 to-white pt-16 pb-12">
    <div class="absolute inset-0 bg-[url('/images/pattern.png')] opacity-10"></div>
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-4xl mx-auto text-center">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 font-lora mb-4">
                Kết quả tìm kiếm tại <span class="text-rose-600">@Model.Location</span>
            </h1>

            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="bg-red-100 text-red-800 p-4 rounded-xl mb-6">
                    @Model.ErrorMessage
                </div>
            }
            else
            {
                <div class="bg-white rounded-xl shadow-md p-4 mb-6 inline-flex flex-col sm:flex-row items-center gap-4">
                    <div class="flex items-center">
                        <i class="fas fa-calendar-day text-rose-500 mr-2"></i>
                        
                        <span class="text-gray-700">@Model.CheckInDate</span>
                        <i class="fas fa-arrow-right mx-2 text-gray-400"></i>
                        <span class="text-gray-700">@Model.CheckOutDate</span>
                    </div>
                    <div class="hidden sm:block w-px h-6 bg-gray-200"></div>
                    <div class="text-gray-700">
                        <span class="font-medium">@Model.Homestays.Count()</span> homestay phù hợp
                    </div>
                </div>
            }

            <div class="flex justify-center">
                <form asp-action="SearchHomestay" method="get" class="w-full max-w-md">
                    <input type="hidden" name="location" value="@(Model.Location)" />
                    <input type="hidden" name="checkInDate" value="@(Model.CheckInDate)" />
                    <input type="hidden" name="checkOutDate" value="@(Model.CheckOutDate)" />
                    <input type="hidden" name="page" value="@Model.CurrentPage" />
                    <div class="relative">
                        <select name="sortOrder" onchange="this.form.submit()"
                                class="appearance-none w-full bg-white border border-gray-200 rounded-full pl-6 pr-10 py-3 focus:outline-none focus:ring-2 focus:ring-rose-500 focus:border-transparent shadow-sm">
                            <option value="popular" selected="@(Model.SortOrder == "popular")">Sắp xếp: Phổ biến nhất</option>
                            <option value="price_asc" selected="@(Model.SortOrder == "price_asc")">Giá: Thấp đến cao</option>
                            <option value="price_desc" selected="@(Model.SortOrder == "price_desc")">Giá: Cao đến thấp</option>
                            <option value="rating_desc" selected="@(Model.SortOrder == "rating_desc")">Đánh giá: Cao nhất</option>
                        </select>
                        <div class="absolute inset-y-0 right-0 flex items-center pr-5 pointer-events-none">
                            <i class="fas fa-chevron-down text-gray-400"></i>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Main Content -->
<section class="py-12 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="text-center py-16 max-w-2xl mx-auto">
                <div class="mx-auto w-32 h-32 bg-rose-50 rounded-full flex items-center justify-center mb-6">
                    <i class="fas fa-home text-5xl text-rose-400"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 font-lora mb-3">@Model.ErrorMessage</h3>
                <p class="text-gray-600 mb-8">
                    Vui lòng thử lại với địa điểm hoặc ngày khác.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/"
                       class="inline-flex items-center justify-center bg-rose-600 hover:bg-rose-700 text-white px-6 py-3 rounded-lg font-medium transition-colors shadow-md hover:shadow-lg">
                        <i class="fas fa-search mr-2"></i> Tìm kiếm lại
                    </a>
                    <a href="/homestay"
                       class="inline-flex items-center justify-center bg-white hover:bg-gray-50 text-gray-800 border border-gray-200 px-6 py-3 rounded-lg font-medium transition-colors shadow-sm hover:shadow-md">
                        <i class="fas fa-list mr-2"></i> Xem tất cả homestay
                    </a>
                </div>
            </div>
        }
        else if (Model.Homestays.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var homestay in Model.Homestays)
                {
                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-2 group">
                        <div class="relative h-64 overflow-hidden">
                            <img src="@(homestay.HinhAnh)" alt="@(homestay.Ten_Homestay)"
                                 class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />

                            <button class="absolute top-4 right-4 bg-white/90 hover:bg-white text-rose-600 p-2.5 rounded-full shadow-md transition-all hover:scale-110">
                                <i class="far fa-heart text-lg"></i>
                            </button>

                            @if (homestay.Hang.HasValue)
                            {
                                <div class="absolute bottom-4 left-4 bg-white/90 text-gray-900 px-3 py-1 rounded-full text-sm font-medium flex items-center shadow-sm">
                                    <i class="fas fa-star text-yellow-400 mr-1"></i>
                                    <span>@homestay.Hang?.ToString("0.0")</span>
                                </div>
                            }
                        </div>

                        <div class="p-6">
                            <div class="flex justify-between items-start mb-3">
                                <h3 class="text-xl font-bold text-gray-900 font-lora line-clamp-1">@homestay.Ten_Homestay</h3>
                                @if (homestay.AvailableRooms > 0)
                                {
                                    <span class="bg-green-100 text-green-800 text-xs px-2.5 py-1 rounded-full whitespace-nowrap">
                                        Còn @homestay.AvailableRooms phòng
                                    </span>
                                }
                                else
                                {
                                    <span class="bg-rose-100 text-rose-800 text-xs px-2.5 py-1 rounded-full whitespace-nowrap">
                                        Hết phòng
                                    </span>
                                }
                            </div>

                            <p class="text-gray-600 mb-4 flex items-center">
                                <i class="fas fa-map-marker-alt text-rose-500 mr-2"></i>
                                <span class="line-clamp-1">@(homestay.DiaChi)</span>
                            </p>

                            <div class="flex items-center justify-between mt-6">
                                <div>
                                    <span class="text-xl font-bold text-rose-600">
                                        @(homestay.MinPrice?.ToString("C0") ?? "Liên hệ")
                                    </span>
                                    <span class="block text-sm text-gray-500">/đêm</span>
                                </div>
                                <a asp-controller="Homestay" asp-action="Details"
                                   asp-route-id="@homestay.ID_Homestay"
                                   asp-route-checkInDate="@Model.CheckInDate"
                                   asp-route-checkOutDate="@Model.CheckOutDate"
                                   class="bg-rose-100 hover:bg-rose-200 text-rose-600 px-5 py-2.5 rounded-lg font-medium transition-all hover:shadow-md flex items-center">
                                    <span>Chi tiết</span>
                                    <i class="fas fa-arrow-right ml-2 text-sm"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Phân trang -->
            @if (Model.TotalPages > 1)
            {
                <div class="mt-16">
                    <nav class="flex justify-center">
                        <ul class="inline-flex items-center -space-x-px">
                            @if (Model.CurrentPage > 1)
                            {
                                <li>
                                    <a asp-action="SearchHomestay"
                                       asp-route-location="@(Model.Location)"
                                       asp-route-checkInDate="@Model.CheckInDate"
                                       asp-route-checkOutDate="@Model.CheckOutDate"
                                       asp-route-page="@(Model.CurrentPage - 1)"
                                       asp-route-sortOrder="@Model.SortOrder"
                                       class="block px-3 py-2 ml-0 leading-tight text-gray-500 bg-white border border-gray-300 rounded-l-lg hover:bg-gray-50 hover:text-rose-600 transition-colors">
                                        <span class="sr-only">Previous</span>
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                            }
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li>
                                    <a asp-action="SearchHomestay"
                                       asp-route-location="@(Model.Location)"
                                       asp-route-checkInDate="@Model.CheckInDate"
                                       asp-route-checkOutDate="@Model.CheckOutDate"
                                       asp-route-page="@i"
                                       asp-route-sortOrder="@Model.SortOrder"
                                       class="px-4 py-2 leading-tight border border-gray-300
                                              @(i == Model.CurrentPage ? "bg-rose-600 text-white border-rose-600" : "bg-white text-gray-500 hover:bg-gray-50 hover:text-rose-600") transition-colors">
                                        @i
                                    </a>
                                </li>
                            }
                            @if (Model.CurrentPage < Model.TotalPages)
                            {
                                <li>
                                    <a asp-action="SearchHomestay"
                                       asp-route-location="@(Model.Location)"
                                       asp-route-checkInDate="@Model.CheckInDate"
                                       asp-route-checkOutDate="@Model.CheckOutDate"
                                       asp-route-page="@(Model.CurrentPage + 1)"
                                       asp-route-sortOrder="@Model.SortOrder"
                                       class="block px-3 py-2 leading-tight text-gray-500 bg-white border border-gray-300 rounded-r-lg hover:bg-gray-50 hover:text-rose-600 transition-colors">
                                        <span class="sr-only">Next</span>
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            }
                        </ul>
                    </nav>
                </div>
            }
        }
        else
        {
            <div class="text-center py-16 max-w-2xl mx-auto">
                <div class="mx-auto w-32 h-32 bg-rose-50 rounded-full flex items-center justify-center mb-6">
                    <i class="fas fa-home text-5xl text-rose-400"></i>
                </div>
                <h3 class="text-2xl font-bold text-gray-900 font-lora mb-3">Không tìm thấy homestay phù hợp</h3>
                <p class="text-gray-600 mb-8">
                    Chúng tôi không tìm thấy homestay nào phù hợp với tiêu chí tìm kiếm của bạn.
                    Vui lòng thử lại với địa điểm hoặc ngày khác.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a href="/"
                       class="inline-flex items-center justify-center bg-rose-600 hover:bg-rose-700 text-white px-6 py-3 rounded-lg font-medium transition-colors shadow-md hover:shadow-lg">
                        <i class="fas fa-search mr-2"></i> Tìm kiếm lại
                    </a>
                    <a href="/homestay"
                       class="inline-flex items-center justify-center bg-white hover:bg-gray-50 text-gray-800 border border-gray-200 px-6 py-3 rounded-lg font-medium transition-colors shadow-sm hover:shadow-md">
                        <i class="fas fa-list mr-2"></i> Xem tất cả homestay
                    </a>
                </div>
            </div>
        }
    </div>
</section>

<!-- Floating Action Button -->
<div class="fixed bottom-8 right-8 z-30">
    <button id="map-view-btn" class="bg-rose-600 hover:bg-rose-700 text-white p-4 rounded-full shadow-xl hover:shadow-2xl transition-all transform hover:scale-110">
        <i class="fas fa-map-marked-alt text-xl"></i>
    </button>
</div>

<!-- Map Modal -->
<div id="map-modal" class="fixed inset-0 bg-black bg-opacity-50 z-40 hidden items-center justify-center p-4">
    <div class="bg-white rounded-2xl w-full max-w-5xl h-[80vh] overflow-hidden relative">
        <button id="close-map-modal" class="absolute top-4 right-4 z-50 bg-white text-gray-800 p-2 rounded-full shadow-md hover:bg-gray-100">
            <i class="fas fa-times"></i>
        </button>
        <div class="h-full w-full bg-gray-200 flex items-center justify-center">
            <div class="text-center p-8">
                <i class="fas fa-map text-5xl text-gray-400 mb-4"></i>
                <h3 class="text-xl font-medium text-gray-700">Bản đồ các homestay</h3>
                <p class="text-gray-500 mt-2">Tính năng đang được phát triển</p>
            </div>
        </div>
    </div>
</div>

<script>
    // Map view toggle functionality
    document.getElementById('map-view-btn').addEventListener('click', function() {
        document.getElementById('map-modal').classList.remove('hidden');
        document.body.style.overflow = 'hidden';
    });

    document.getElementById('close-map-modal').addEventListener('click', function() {
        document.getElementById('map-modal').classList.add('hidden');
        document.body.style.overflow = '';
    });
</script>
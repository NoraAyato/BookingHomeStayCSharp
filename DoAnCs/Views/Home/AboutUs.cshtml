            <p class="text-xl md:text-2xl max-w-3xl mx-auto" data-aos="fade-down" data-aos-delay="100">Hành trình đem đến những trải nghiệm nghỉ dưỡng đẳng cấp và đáng nhớ</p>
        </div>
    </div>

    <!-- Our Story -->
    <section class="py-20 bg-white">

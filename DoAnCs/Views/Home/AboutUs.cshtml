                            <span class="block text-4xl font-bold">3+</span>
                            <span class="block text-sm">Năm kinh nghiệm</span>
                        </div>
                    </div>
                </div>
                <div class="lg:w-1/2" data-aos="fade-left" data-aos-delay="200">

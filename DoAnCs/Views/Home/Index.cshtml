@{
    ViewData["Title"] = "Rose Homestay - Trải Nghiệm Nghỉ Dưỡng Đẳng Cấp";
}

<!-- Hero Section với hiệu ứng parallax và gradient overlay -->
<section class="relative h-screen min-h-[800px] flex items-center justify-center overflow-hidden">
    <!-- Background Image với hiệu ứng parallax -->
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-gray-900/40 via-gray-900/30 to-gray-900/50"></div>
        <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80"
             alt="Homestay sang trọng"
             class="w-full h-full object-cover object-center transform scale-125 md:scale-100 transition-transform duration-1000 ease-out"
             id="hero-parallax">
    </div>

    <!-- Hero Content với animation -->
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 relative z-10 text-center" data-aos="fade-up" data-aos-duration="1000">
        <div class="max-w-4xl mx-auto">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white font-lora mb-6 leading-tight">
                <span class="text-rose-300 animate-float">Kỳ nghỉ hoàn hảo</span> bắt đầu từ <span class="text-rose-300 animate-float animation-delay-2000">ngôi nhà hoàn hảo</span>
            </h1>
            <p class="text-xl text-white/90 mb-10 font-lora max-w-2xl mx-auto">
                Khám phá hơn 1000 homestay cao cấp trên khắp Việt Nam với dịch vụ đẳng cấp và tiện nghi hiện đại
            </p>
        </div>

        <!-- Search Bar với thiết kế mới nổi bật -->
        <div id="homestaySearchForm" class="bg-white/90 backdrop-blur-md rounded-2xl shadow-2xl p-6 max-w-5xl mx-auto border border-white/20" data-aos="fade-up" data-aos-delay="300">
            <form action="@Url.Action("SearchHomestay", "Home")" method="get" class="grid grid-cols-1 md:grid-cols-4 gap-4">
                @Html.AntiForgeryToken()

                <!-- Địa điểm -->
                <div class="relative group">
                    <label class="block text-sm font-medium text-gray-700 mb-1 text-left flex items-center">
                        <i class="fas fa-map-marker-alt text-rose-500 mr-2"></i> Địa điểm
                    </label>
                    <div class="relative">
                        <input type="text"
                               name="location"
                               id="location"
                               placeholder="Nhập thành phố, khu vực..."
                               class="w-full pl-4 pr-10 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all duration-300 bg-white/80 hover:border-rose-300 group-hover:border-rose-300"
                               autocomplete="off"
                               required>
                        <span class="text-red-500 text-sm mt-1 error-message"></span>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-chevron-down text-gray-400 group-hover:text-rose-500 transition-colors duration-300"></i>
                        </div>
                    </div>
                </div>

                <!-- Ngày nhận phòng -->
                <div class="relative group">
                    <label class="block text-sm font-medium text-gray-700 mb-1 text-left flex items-center">
                        <i class="fas fa-calendar-check text-rose-500 mr-2"></i> Nhận phòng
                    </label>
                    <div class="relative">
                        <input type="date"
                               name="checkInDate"
                               id="checkInDate"
                               class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all duration-300 bg-white/80 hover:border-rose-300 group-hover:border-rose-300"
                               required
                               min="@DateTime.Today.ToString("yyyy-MM-dd")">
                        <span class="text-red-500 text-sm mt-1 error-message"></span>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-calendar-day text-gray-400 group-hover:text-rose-500 transition-colors duration-300"></i>
                        </div>
                    </div>
                </div>

                <!-- Ngày trả phòng -->
                <div class="relative group">
                    <label class="block text-sm font-medium text-gray-700 mb-1 text-left flex items-center">
                        <i class="fas fa-calendar-times text-rose-500 mr-2"></i> Trả phòng
                    </label>
                    <div class="relative">
                        <input type="date"
                               name="checkOutDate"
                               id="checkOutDate"
                               class="w-full px-4 py-3 border border-gray-200 rounded-lg focus:ring-2 focus:ring-rose-500 focus:border-transparent transition-all duration-300 bg-white/80 hover:border-rose-300 group-hover:border-rose-300"
                               required>
                        <span class="text-red-500 text-sm mt-1 error-message"></span>
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                            <i class="fas fa-calendar-day text-gray-400 group-hover:text-rose-500 transition-colors duration-300"></i>
                        </div>
                    </div>
                </div>

                <!-- Nút tìm kiếm -->
                <div class="flex items-end">
                    <button type="submit"
                            class="w-full h-full bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white py-3 px-6 rounded-lg font-medium transition-all duration-300 shadow-lg hover:shadow-xl flex items-center justify-center transform hover:-translate-y-1 active:translate-y-0">
                        <i class="fas fa-search mr-2"></i> Tìm kiếm
                    </button>
                </div>
            </form>
        </div>

        <!-- Địa điểm phổ biến -->
        <div id="popular-areas" class="mt-8 flex flex-wrap justify-center gap-3">
            <span class="text-white/80 font-medium">Địa điểm phổ biến:</span>
        </div>

    </div>

    <!-- Scroll Down Indicator với animation -->
    <div class="absolute bottom-10 left-1/2 transform -translate-x-1/2 z-10 animate-bounce-slow">
        <a href="#featured" class="text-white hover:text-rose-300 transition-colors duration-300">
            <i class="fas fa-chevron-down text-2xl"></i>
        </a>
    </div>
</section>

<!-- Featured Homestays -->
<section id="featured" class="py-20 bg-gradient-to-b from-white to-gray-50 w-full">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="inline-block px-3 py-1 text-sm font-medium rounded-full bg-rose-100 text-rose-600 mb-4">Khám phá</span>
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 font-lora mb-4">
                Homestay <span class="text-rose-600">Nổi Bật</span>
            </h2>
            <p class="text-lg text-gray-600 max-w-2xl mx-auto font-lora">
                Những homestay được yêu thích nhất với đánh giá 5 sao từ khách hàng
            </p>
        </div>

        <!-- Loading Indicator với Skeleton -->
        <div id="homestay-loading" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8">
            <div class="bg-gray-100 rounded-2xl h-96 animate-pulse">
                <div class="h-48 bg-gray-200 rounded-t-2xl"></div>
                <div class="p-4 space-y-3">
                    <div class="h-4 bg-gray-200 rounded w-3/4"></div>
                    <div class="h-4 bg-gray-200 rounded w-1/2"></div>
                    <div class="h-4 bg-gray-200 rounded w-2/3"></div>
                    <div class="h-4 bg-gray-200 rounded w-1/4"></div>
                </div>
            </div>
            <!-- Thêm 4 skeleton items tương tự -->
        </div>

        <!-- Homestay Grid -->
        <div id="homestay-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-8 hidden">
            <!-- Các mục homestay sẽ được thêm động bằng JavaScript -->
        </div>

        <div class="text-center mt-12" data-aos="fade-up">
            <a href="/Homestay/Index?khuVucName"
               class="inline-flex items-center bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white px-8 py-3 rounded-lg font-medium transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1 active:translate-y-0">
                Xem tất cả homestay
                <i class="fas fa-arrow-right ml-2 transition-transform duration-300 group-hover:translate-x-1"></i>
            </a>
        </div>
    </div>
</section>


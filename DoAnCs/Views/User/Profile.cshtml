                .then(data => {
                    if (data.success) {
                        document.getElementById('modalMaPDPhong').textContent = data.data.maPDPhong;
                        document.getElementById('modalNgayLap').textContent = data.data.ngayLap;

                        let statusHtml = '';
                        switch (data.data.trangThai) {
                            case 'Đã xác nhận':
                                statusHtml = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800"><i class="fas fa-check-circle mr-1"></i> ${data.data.trangThai}</span>`;
                                break;
                            case 'Chờ xác nhận':
                                statusHtml = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800"><i class="fas fa-clock mr-1"></i> ${data.data.trangThai}</span>`;
                                break;
                            case 'Hoàn thành':
                                statusHtml = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800"><i class="fas fa-calendar-check mr-1"></i> ${data.data.trangThai}</span>`;
                                break;

        function requestOtp() {
             fetch('/Account/SendOTP', { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        showNotification('success', 'Mã OTP đã được gửi đến email của bạn.');
                    } else {
                        showNotification('error', data.message || 'Không thể gửi OTP.');
                    }
                })
                .catch(error => {
                    showNotification('error', 'Lỗi khi gửi OTP: ' + error.message);
                    console.error(error);
                });
        }

        function startOtpCountdownUser() {
           
            const countdownElement = document.getElementById('countdown');
            const resendButton = document.getElementById('resendOtpButton');
            let timeLeft = 60;

            resendButton.disabled = true;
            const countdown = setInterval(() => {
                timeLeft--;
                countdownElement.textContent = timeLeft;
                if (timeLeft <= 0) {
                    clearInterval(countdown);
                    resendButton.disabled = false;
                    countdownElement.textContent = '60';
                }
            }, 1000);
        }

        function resendOtp() {
            requestOtp();
            startOtpCountdownUser();
        }

        function restrictToNumbers(input) {
            input.value = input.value.replace(/[^0-9]/g, '');
        }

        function handleOtpPaste(event) {
            const pastedData = (event.clipboardData || window.clipboardData).getData('text');
            if (/^\d{6}$/.test(pastedData)) {
                document.getElementById('otpInputuser').value = pastedData;
                verifyOtpUser();
            }
            event.preventDefault();
        }

        function verifyOtpUser() {
            const otp = document.getElementById('otpInputuser').value;
            if (!otp || otp.length !== 6) {
                document.getElementById('otpError').textContent = 'Mã OTP phải có 6 chữ số.';
                document.getElementById('otpError').classList.remove('hidden');
                return;
            }

            fetch('/Account/VerifyOtp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ otp })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    document.getElementById('otpForm').classList.add('hidden');
                    document.getElementById('passwordForm').classList.remove('hidden');
                    document.getElementById('otpError').classList.add('hidden');
                } else {
                    document.getElementById('otpError').textContent = data.message || 'Mã OTP không hợp lệ.';
                    document.getElementById('otpError').classList.remove('hidden');
                }
            })
            .catch(error => {
                document.getElementById('otpError').textContent = 'Lỗi khi xác minh OTP.';
                document.getElementById('otpError').classList.remove('hidden');
                console.error(error);
            });
        }

        function validatePassword() {
            const newPassword = document.getElementById('newPassword').value;
          
            const confirmPassword = document.getElementById('changePasswordConfirm').value;
        
            let hasError = false;

            document.getElementById('newPasswordError').classList.add('hidden');
            document.getElementById('confirmPasswordErrorUser').classList.add('hidden');

            if (newPassword.length < 8) {
                document.getElementById('newPasswordError').textContent = 'Mật khẩu mới phải có ít nhất 8 ký tự.';
                document.getElementById('newPasswordError').classList.remove('hidden');
                hasError = true;
            }
            if (newPassword !== confirmPassword) {
                document.getElementById('confirmPasswordErrorUser').textContent = 'Mật khẩu xác nhận không khớp.';
                document.getElementById('confirmPasswordErrorUser').classList.remove('hidden');
                hasError = true;
            }

            return !hasError;
        }

        document.getElementById('changePasswordForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const submitButton = document.getElementById('changePasswordButton');
            const submitText = document.getElementById('changePasswordText');
            const submitSpinner = document.getElementById('changePasswordSpinner');

            if (!validatePassword()) return;

            submitButton.disabled = true;
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            const formData = new FormData(this);
            const data = {
                oldPassword: formData.get('oldPassword'),
                newPassword: formData.get('newPassword')
            };

            fetch('/Account/ChangePassword', {

@using DoAnCs.Models.ViewModels
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    Layout = "_Layout";
}

<div class="bg-gray-50 min-h-screen">
    <!-- Notification Center -->
    <div id="notification" class="fixed top-4 right-4 z-50 hidden">
        <div class="px-6 py-4 rounded-lg shadow-lg border-l-4 bg-white max-w-sm">
            <div class="flex items-center">
                <div id="notification-icon"></div>
                <div class="ml-3">
                    <p id="notification-message" class="text-sm"></p>
                </div>
                <button onclick="hideNotification()" class="ml-auto text-gray-400 hover:text-gray-500">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Loading Spinner -->
    <div id="pageLoading" class="fixed inset-0 bg-gray-500 bg-opacity-75 flex items-center justify-center z-50 hidden">
        <div class="spinner border-4 border-t-rose-600 rounded-full w-12 h-12 animate-spin"></div>
    </div>

    <!-- Modal for Booking Details -->
    <div id="bookingDetailsModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-4xl sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="modal-title">Chi tiết phiếu đặt phòng</h3>
                        <button onclick="closeModal('bookingDetailsModal')" class="text-gray-400 hover:text-gray-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <div class="grid grid-cols-2 gap-4 mb-4">
                            <div>
                                <p class="text-sm text-gray-500">Mã phiếu</p>
                                <p class="font-medium" id="modalMaPDPhong"></p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500">Ngày lập</p>
                                <p class="font-medium" id="modalNgayLap"></p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500">Trạng thái</p>
                                <p class="font-medium" id="modalTrangThai"></p>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500">Tổng tiền</p>
                                <p class="font-medium" id="modalTongTien"></p>
                            </div>
                        </div>
                        <div class="mt-4">
                            <h4 class="text-md font-medium text-gray-900 mb-3">Danh sách phòng và dịch vụ</h4>
                            <div id="modalChiTietPhongs" class="space-y-4"></div>
                        </div>
                    </div>
                </div>
                <div class="bg-gray-50 px-6 py-3 flex justify-end">
                    <button onclick="closeModal('bookingDetailsModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                        Đóng
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Updating Profile -->
    <div id="updateProfileModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="update-profile-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-lg sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="update-profile-title">Cập nhật thông tin cá nhân</h3>
                        <button onclick="closeModal('updateProfileModal')" class="text-gray-400 hover:text-gray-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <form id="profileForm" asp-action="Profile" asp-controller="User" method="post">
                            @Html.AntiForgeryToken()
                            <div class="space-y-6">
                                <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                                    <!-- Full Name -->
                                    <div class="sm:col-span-3">
                                        <label for="FullName" class="block text-sm font-medium text-gray-700">Họ và tên</label>
                                        <div class="mt-1">
                                            <input id="FullName" name="FullName" type="text" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3">
                                            <span id="FullNameError" class="text-red-500 text-xs"></span>
                                        </div>
                                    </div>
                                    <!-- Email (display only) -->
                                    <div class="sm:col-span-3">
                                        <label class="block text-sm font-medium text-gray-700">Email</label>
                                        <div class="mt-1">
                                            <p id="modalEmail" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2"></p>
                                        </div>
                                    </div>
                                    <!-- Phone Number -->
                                    <div class="sm:col-span-3">
                                        <label for="PhoneNumber" class="block text-sm font-medium text-gray-700">Số điện thoại</label>
                                        <div class="mt-1">
                                            <input id="PhoneNumber" name="PhoneNumber" type="tel" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" required>
                                            <span id="PhoneNumberError" class="text-red-500 text-xs"></span>
                                        </div>
                                    </div>
                                    <!-- Date of Birth -->
                                    <div class="sm:col-span-3">
                                        <label for="DateOfBirth" class="block text-sm font-medium text-gray-700">Ngày sinh</label>
                                        <div class="mt-1">
                                            <input id="DateOfBirth" name="DateOfBirth" type="date" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" required>
                                            <p id="DateOfBirthError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                    <!-- Address -->
                                    <div class="sm:col-span-6">
                                        <label for="Address" class="block text-sm font-medium text-gray-700">Địa chỉ</label>
                                        <div class="mt-1">
                                            <input id="Address" name="Address" type="text" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" required>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-6 flex justify-end space-x-3">
                                <button type="button" onclick="closeModal('updateProfileModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                    Hủy
                                </button>
                                <button type="submit" id="submitButton" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                    <span id="submitText">Lưu thay đổi</span>
                                    <span id="submitSpinner" class="hidden ml-2"><i class="fas fa-spinner fa-spin"></i></span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Changing Password -->
    <div id="changePasswordModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="change-password-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-lg sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="change-password-title">Thay đổi mật khẩu</h3>
                        <button onclick="closeModal('changePasswordModal')" class="text-gray-400 hover:text-gray-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <!-- OTP Verification Form -->
                        <div id="otpForm" class="">
                            <p class="text-sm text-gray-600 mb-4">Nhập mã OTP 6 số được gửi đến email <strong id="otpEmail"></strong>.</p>
                            <div class="mt-1">
                                <input id="otpInputuser" type="text" maxlength="6" placeholder="Nhập mã OTP" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3 text-center" onpaste="handleOtpPaste(event)" oninput="restrictToNumbers(this)">
                                <p id="otpError" class="text-red-500 text-xs mt-1 hidden"></p>
                            </div>
                            <div class="mt-4 flex items-center justify-between">
                                <button id="resendOtpButton" onclick="resendOtp()" disabled class="text-sm text-rose-600 hover:text-rose-700 transition-colors">
                                    Gửi lại mã (<span id="countdown">60</span>s)
                                </button>
                                <button onclick="verifyOtpUser()" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                    Xác minh
                                </button>
                            </div>
                        </div>
                        <!-- Change Password Form -->
                        <div id="passwordForm" class="hidden">
                            <form id="changePasswordForm">
                                <div class="space-y-4">
                                    <!-- Old Password -->
                                    <div>
                                        <label for="oldPassword" class="block text-sm font-medium text-gray-700">Mật khẩu cũ</label>
                                        <div class="mt-1">
                                            <input id="oldPassword" name="oldPassword" type="password" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3">
                                            <p id="oldPasswordError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                    <!-- New Password -->
                                    <div>
                                        <label for="newPassword" class="block text-sm font-medium text-gray-700">Mật khẩu mới</label>
                                        <div class="mt-1">
                                            <input id="newPassword" name="newPassword" type="password" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" oninput="validatePassword()">
                                            <p id="newPasswordError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                    <!-- Confirm New Password -->
                                    <div>
                                        <label for="changePasswordConfirm" class="block text-sm font-medium text-gray-700">Xác nhận mật khẩu mới</label>
                                        <div class="mt-1">
                                            <input id="changePasswordConfirm" name="changePasswordConfirm" type="password" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" oninput="validatePassword()">
                                            <p id="confirmPasswordErrorUser" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                </div>
                                <div class="mt-6 flex justify-end space-x-3">
                                    <button type="button" onclick="closeModal('changePasswordModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                        Hủy
                                    </button>
                                    <button type="submit" id="changePasswordButton" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                        <span id="changePasswordText">Lưu thay đổi</span>
                                        <span id="changePasswordSpinner" class="hidden ml-2"><i class="fas fa-spinner fa-spin"></i></span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Adding Services -->
    <div id="addServiceModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="add-service-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-2xl sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="add-service-title">Đăng ký thêm dịch vụ</h3>
                        <button onclick="closeModal('addServiceModal')" class="text-gray-400 hover:text-gray-500" aria-label="Đóng modal">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <div id="addServiceLoading" class="hidden flex justify-center items-center py-4">
                            <i class="fas fa-spinner fa-spin text-rose-600 text-2xl"></i>
                        </div>
                        <div id="addServiceContent">
                            <p class="text-lg font-medium"><i class="fas fa-ticket-alt text-rose-500 mr-2"></i> <span id="addServiceMaPDPhong"></span></p>
                            <form id="addServiceForm" class="mt-4">
                                @Html.AntiForgeryToken()
                                <div class="space-y-6">
                                    <!-- Danh sách phòng -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-3">Chọn dịch vụ cho các phòng</label>
                                        <div id="roomServiceList" class="space-y-6"></div>
                                        <p id="roomError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        <p id="serviceError" class="text-red-500 text-xs mt-1 hidden"></p>
                                    </div>
                                </div>
                                <div class="mt-6 flex justify-end space-x-3">
                                    <button type="button" onclick="closeModal('addServiceModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                        Hủy
                                    </button>
                                    <button type="submit" id="submitServiceButton" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                        <span id="submitServiceText">Thêm dịch vụ</span>
                                        <span id="submitServiceSpinner" class="hidden ml-2"><i class="fas fa-spinner fa-spin"></i></span>
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Cancel Booking -->
    <div id="cancelBookingModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="cancel-booking-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-lg sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="cancel-booking-title">Hủy phiếu đặt phòng</h3>
                        <button onclick="closeModal('cancelBookingModal')" class="text-gray-400 hover:text-gray-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <form id="cancelBookingForm">
                            @Html.AntiForgeryToken()
                            <div class="space-y-6">
                                <!-- Mã phiếu -->
                                <div>
                                    <label class="block text-sm font-medium text-gray-700">Mã phiếu</label>
                                    <div class="mt-1">
                                        <input id="cancelMaPDPhong" name="MaPDPhong" type="text" readonly class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm py-2 px-3">
                                    </div>
                                </div>
                                <!-- Thông báo hủy -->
                                <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
                                    <div class="flex">
                                        <div class="flex-shrink-0">
                                            <i class="fas fa-exclamation-circle text-yellow-500"></i>
                                        </div>
                                        <div class="ml-3">
                                            <p class="text-sm text-yellow-700">
                                                Việc hủy phiếu đặt phòng có thể áp dụng phí hủy theo chính sách của homestay. Vui lòng kiểm tra kỹ trước khi xác nhận.
                                            </p>
                                        </div>
                                    </div>
                                </div>
                                <!-- Lý do hủy -->
                                <div>
                                    <label for="LyDo" class="block text-sm font-medium text-gray-700">Lý do hủy (tùy chọn)</label>
                                    <div class="mt-1">
                                        <textarea id="LyDo" name="LyDo" rows="3" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" placeholder="Nhập lý do hủy phòng (nếu có)"></textarea>
                                    </div>
                                </div>
                                <!-- Thông tin hoàn tiền -->
                                <div class="border-t border-gray-200 pt-4">
                                    <h4 class="text-sm font-medium text-gray-700 mb-2">Thông tin hoàn tiền (nếu có)</h4>
                                    <!-- Tên ngân hàng -->
                                    <div class="mt-2">
                                        <label for="TenNganHang" class="block text-sm font-medium text-gray-700">Tên ngân hàng</label>
                                        <div class="mt-1">
                                            <input id="TenNganHang" name="TenNganHang" type="text" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" placeholder="VD: Vietcombank">
                                            <p id="tenNganHangError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                    <!-- Số tài khoản -->
                                    <div class="mt-2">
                                        <label for="SoTaiKhoan" class="block text-sm font-medium text-gray-700">Số tài khoản</label>
                                        <div class="mt-1">
                                            <input id="SoTaiKhoan" name="SoTaiKhoan" type="text" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" placeholder="VD: 1234567890">
                                            <p id="soTaiKhoanError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-6 flex justify-end space-x-3">
                                <button type="button" onclick="closeModal('cancelBookingModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                    Hủy
                                </button>
                                <button type="submit" id="submitCancelButton" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                    <span id="submitCancelText">Xác nhận hủy</span>
                                    <span id="submitCancelSpinner" class="hidden ml-2"><i class="fas fa-spinner fa-spin"></i></span>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for Review (Add/View) -->
    <div id="reviewModal" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="review-title" role="dialog" aria-modal="true">
        <div class="flex items-center justify-center min-h-screen px-4 text-center">
            <div class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" aria-hidden="true"></div>
            <div class="inline-block align-middle bg-white rounded-lg text-left overflow-hidden shadow-xl transform transition-all sm:max-w-2xl sm:w-full">
                <div class="bg-white px-6 py-4">
                    <div class="flex justify-between items-center border-b pb-3">
                        <h3 class="text-lg font-medium text-gray-900" id="review-title">
                            <i class="fas fa-star text-yellow-400 mr-2"></i>
                            <span id="review-modal-title">Đánh giá phiếu đặt phòng</span>
                        </h3>
                        <button onclick="closeModal('reviewModal')" class="text-gray-400 hover:text-gray-500">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                    <div class="mt-4">
                        <!-- Add Review Form -->
                        <div id="addReviewFormContainer" class="hidden">
                            <form id="addReviewForm">
                                @Html.AntiForgeryToken()
                                <div class="space-y-6">
                                    <!-- Mã phiếu -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700">Mã phiếu</label>
                                        <div class="mt-1">
                                            <input id="reviewMaPDPhong" name="MaPDPhong" type="text" readonly class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm py-2 px-3">
                                        </div>
                                    </div>
                                    <!-- Điểm đánh giá -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Đánh giá của bạn</label>
                                        <div class="flex items-center space-x-1">
                                            <input type="hidden" id="rating" name="Rating" value="5">
                                            <button type="button" onclick="setRating(1)" class="text-2xl focus:outline-none">
                                                <i class="far fa-star rating-star" data-rating="1"></i>
                                            </button>
                                            <button type="button" onclick="setRating(2)" class="text-2xl focus:outline-none">
                                                <i class="far fa-star rating-star" data-rating="2"></i>
                                            </button>
                                            <button type="button" onclick="setRating(3)" class="text-2xl focus:outline-none">
                                                <i class="far fa-star rating-star" data-rating="3"></i>
                                            </button>
                                            <button type="button" onclick="setRating(4)" class="text-2xl focus:outline-none">
                                                <i class="far fa-star rating-star" data-rating="4"></i>
                                            </button>
                                            <button type="button" onclick="setRating(5)" class="text-2xl focus:outline-none">
                                                <i class="far fa-star rating-star" data-rating="5"></i>
                                            </button>
                                            <span class="ml-2 text-sm font-medium text-gray-700" id="rating-text">Tuyệt vời</span>
                                        </div>
                                        <p id="ratingError" class="text-red-500 text-xs mt-1 hidden"></p>
                                    </div>
                                    <!-- Mẫu bình luận -->
                                    <div>
                                        <label class="block text-sm font-medium text-gray-700 mb-2">Mẫu bình luận (chọn một)</label>
                                        <div class="grid grid-cols-2 gap-2">
                                            <button type="button" onclick="setComment('Trải nghiệm tuyệt vời, sẽ quay lại!')" class="text-left p-2 border border-gray-200 rounded-md hover:bg-rose-50 hover:border-rose-200 transition-colors">
                                                <p class="text-sm font-medium">Trải nghiệm tuyệt vời</p>
                                                <p class="text-xs text-gray-500">Sẽ quay lại!</p>
                                            </button>
                                            <button type="button" onclick="setComment('Phòng sạch sẽ, view đẹp')" class="text-left p-2 border border-gray-200 rounded-md hover:bg-rose-50 hover:border-rose-200 transition-colors">
                                                <p class="text-sm font-medium">Phòng sạch sẽ</p>
                                                <p class="text-xs text-gray-500">View đẹp</p>
                                            </button>
                                            <button type="button" onclick="setComment('Nhân viên thân thiện, nhiệt tình')" class="text-left p-2 border border-gray-200 rounded-md hover:bg-rose-50 hover:border-rose-200 transition-colors">
                                                <p class="text-sm font-medium">Nhân viên thân thiện</p>
                                                <p class="text-xs text-gray-500">Nhiệt tình</p>
                                            </button>
                                            <button type="button" onclick="setComment('Vị trí thuận tiện, dễ tìm')" class="text-left p-2 border border-gray-200 rounded-md hover:bg-rose-50 hover:border-rose-200 transition-colors">
                                                <p class="text-sm font-medium">Vị trí thuận tiện</p>
                                                <p class="text-xs text-gray-500">Dễ tìm</p>
                                            </button>
                                        </div>
                                    </div>
                                    <!-- Bình luận -->
                                    <div>
                                        <label for="binhLuan" class="block text-sm font-medium text-gray-700">Bình luận của bạn</label>
                                        <div class="mt-1">
                                            <textarea id="binhLuan" name="BinhLuan" rows="3" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm py-2 px-3" placeholder="Hãy chia sẻ trải nghiệm của bạn..."></textarea>
                                            <p id="binhLuanError" class="text-red-500 text-xs mt-1 hidden"></p>
                                        </div>
                                    </div>
                                    <!-- Hình ảnh -->
                                    <div>
                                        <label for="hinhAnh" class="block text-sm font-medium text-gray-700">Hình ảnh</label>
                                        <div class="mt-1">
                                            <input id="hinhAnh" name="HinhAnh" type="file" accept="image/*" multiple class="hidden" onchange="previewImages(this)">
                                            <div class="flex items-center space-x-4">
                                                <label for="hinhAnh" class="cursor-pointer">
                                                    <div class="w-24 h-24 border-2 border-dashed border-gray-300 rounded-md flex items-center justify-center text-gray-400 hover:text-rose-500 hover:border-rose-400 transition-colors">
                                                        <i class="fas fa-camera text-2xl"></i>
                                                    </div>
                                                </label>
                                                <div id="imagePreviewContainer" class="flex space-x-2"></div>
                                            </div>
                                        </div>
                                        <p id="hinhAnhError" class="text-red-500 text-xs mt-1 hidden"></p>
                                    </div>
                                </div>
                                <div class="mt-6 flex justify-end space-x-3">
                                    <button type="button" onclick="closeModal('reviewModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                        Hủy
                                    </button>
                                    <button type="submit" id="submitReviewButton" class="inline-flex justify-center rounded-md border border-transparent bg-rose-600 py-2 px-4 text-sm font-medium text-white shadow-sm hover:bg-rose-700">
                                        <span id="submitReviewText">Gửi đánh giá</span>
                                        <span id="submitReviewSpinner" class="hidden ml-2"><i class="fas fa-spinner fa-spin"></i></span>
                                    </button>
                                </div>
                            </form>
                        </div>
                        <!-- View Review Content -->
                        <div id="viewReviewContent" class="hidden">
                            <div class="flex items-start space-x-4">
                                <div class="flex-shrink-0">
                                    <img id="reviewerAvatar" class="h-10 w-10 rounded-full" src="/img/default-avatar.jpg" alt="Ảnh đại diện">
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-gray-900" id="reviewerName"></p>
                                    <div class="flex items-center mt-1">
                                        <div id="reviewStars" class="flex"></div>
                                        <p class="ml-2 text-sm text-gray-500" id="reviewDate"></p>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-4 pl-14">
                                <p class="text-sm text-gray-700" id="reviewComment"></p>
                                <div id="reviewImages" class="mt-3 grid grid-cols-3 gap-2"></div>
                                <div class="mt-6 flex justify-end">
                                    <button onclick="closeModal('reviewModal')" class="rounded-md border border-gray-300 bg-white py-2 px-4 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50">
                                        Đóng
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <!-- Header section -->
        <div class="text-center mb-12">
            <h1 class="text-4xl font-bold text-gray-900 font-lora">Hồ sơ cá nhân</h1>
            <p class="mt-3 text-lg text-gray-600">Quản lý thông tin cá nhân và lịch sử đặt phòng của bạn</p>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Sidebar Profile Card -->
            <div class="lg:w-1/3">
                <div class="bg-white rounded-xl shadow-md overflow-hidden">
                    <!-- Cover photo -->
                    <div class="h-32 bg-gradient-to-r from-rose-500 to-rose-600 relative">
                        <div class="absolute -bottom-16 left-1/2 transform -translate-x-1/2">
                            <div class="relative group">
                                <img id="profileImagePreview" src="/img/default-avatar.jpg" alt="Profile picture" class="w-32 h-32 rounded-full border-4 border-white shadow-lg object-cover">
                                <!-- Upload button -->
                                <label for="profileImageUpload" class="absolute bottom-0 right-0 bg-rose-600 text-white p-2 rounded-full cursor-pointer shadow-md hover:bg-rose-700 transition-all">
                                    <i class="fas fa-camera"></i>
                                    <input id="profileImageUpload" name="profileImage" type="file" accept="image/*" class="hidden">
                                </label>
                            </div>
                        </div>
                    </div>
                    <!-- User info -->
                    <div class="pt-20 pb-6 px-6 text-center">
                        <h2 id="profileFullName" class="text-2xl font-bold text-gray-900 font-lora">Đang tải...</h2>
                        <p id="profileEmail" class="text-gray-600 mt-1"></p>
                        <p id="profilePhoneNumber" class="text-gray-600"></p>
                        <!-- Status badge -->
                        <div class="mt-3">
                            <span id="profileTrangThai" class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium"></span>
                        </div>
                    </div>
                    <!-- Points section -->
                    <div class="bg-rose-50 p-4 mx-4 mb-6 rounded-lg">
                        <div class="flex items-center justify-center">
                            <div class="p-3 rounded-full bg-rose-100 text-rose-600">
                                <i class="fas fa-gem text-xl"></i>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm font-medium text-gray-500">Điểm tích lũy</p>
                                <p id="profileTichDiem" class="text-2xl font-bold text-rose-600">0</p>
                            </div>
                        </div>
                    </div>
                    <!-- Navigation tabs -->
                    <div class="border-t border-gray-200">
                        <nav class="flex flex-col">
                            <button id="profileTab" class="tab-button text-left px-6 py-4 text-gray-700 hover:bg-gray-50 font-medium border-l-4 border-rose-500 bg-rose-50">
                                <i class="fas fa-user-circle mr-3 text-rose-600"></i> Thông tin cá nhân
                            </button>
                            <button id="bookingsTab" class="tab-button text-left px-6 py-4 text-gray-500 hover:bg-gray-50 font-medium border-l-4 border-transparent">
                                <i class="fas fa-calendar-alt mr-3"></i> Đặt phòng của tôi
                            </button>
                            <button id="securityTab" class="tab-button text-left px-6 py-4 text-gray-500 hover:bg-gray-50 font-medium border-l-4 border-transparent">
                                <i class="fas fa-lock mr-3"></i> Bảo mật
                            </button>
                        </nav>
                    </div>
                </div>
            </div>

            <!-- Main Content Area -->
            <div class="lg:w-2/3">
                <!-- Profile Information Tab -->
                <div id="profileContent" class="tab-content bg-white rounded-xl shadow-md p-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-6 font-lora border-b pb-3">Thông tin cơ bản</h3>
                    <div class="space-y-6">
                        <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
                            <!-- Full Name -->
                            <div class="sm:col-span-3">
                                <label class="block text-sm font-medium text-gray-700">Họ và tên</label>
                                <div class="mt-1">
                                    <p id="infoFullName" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2">Đang tải...</p>
                                </div>
                            </div>
                            <!-- Email -->
                            <div class="sm:col-span-3">
                                <label class="block text-sm font-medium text-gray-700">Email</label>
                                <div class="mt-1">
                                    <p id="infoEmail" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2"></p>
                                </div>
                            </div>
                            <!-- Phone Number -->
                            <div class="sm:col-span-3">
                                <label class="block text-sm font-medium text-gray-700">Số điện thoại</label>
                                <div class="mt-1">
                                    <p id="infoPhoneNumber" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2"></p>
                                </div>
                            </div>
                            <!-- Date of Birth -->
                            <div class="sm:col-span-3">
                                <label class="block text-sm font-medium text-gray-700">Ngày sinh</label>
                                <div class="mt-1">
                                    <p id="infoDateOfBirth" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2"></p>
                                </div>
                            </div>
                            <!-- Address -->
                            <div class="sm:col-span-6">
                                <label class="block text-sm font-medium text-gray-700">Địa chỉ</label>
                                <div class="mt-1">
                                    <p id="infoAddress" class="block w-full rounded-md border-gray-300 shadow-sm bg-gray-100 sm:text-sm p-2"></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Bookings Tab -->
                <div id="bookingsContent" class="tab-content hidden bg-white rounded-xl shadow-md p-6">
                    <div class="flex justify-between items-center mb-6 border-b pb-3">
                        <h3 class="text-xl font-bold text-gray-900 font-lora">Lịch sử đặt phòng</h3>
                        <div class="text-sm text-gray-500">
                            Tổng: <span id="totalBookings" class="font-medium">0</span> phiếu
                        </div>
                    </div>
                    <div id="bookingsList" class="space-y-4">
                        <!-- Bookings will be populated here -->
                    </div>
                    <!-- Pagination -->
                    <div id="pagination" class="mt-6 flex items-center justify-between border-t border-gray-200 pt-4 hidden">
                        <!-- Pagination will be populated here -->
                    </div>
                </div>

                <!-- Security Tab -->
                <div id="securityContent" class="tab-content hidden bg-white rounded-xl shadow-md p-6">
                    <div class="text-center py-12">
                        <div class="mx-auto flex items-center justify-center h-12 w-12 rounded-full bg-rose-100">
                            <i class="fas fa-lock text-rose-600"></i>
                        </div>
                        <h3 class="mt-3 text-xl font-bold text-gray-900 font-lora">Bảo mật</h3>
                        <p class="mt-2 text-gray-500">Quản lý thông tin cá nhân và mật khẩu của bạn một cách an toàn.</p>
                        <div class="mt-6 flex justify-center space-x-4">
                            <button onclick="showUpdateProfileModal()" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-rose-600 hover:bg-rose-700">
                                <i class="fas fa-edit mr-2"></i> Thay đổi thông tin
                            </button>
                            <button id="showchangePasswordButton" onclick="showChangePasswordModal()" class="hidden inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-rose-600 hover:bg-rose-700">
                                <i class="fas fa-key mr-2"></i> Thay đổi mật khẩu
                            </button>

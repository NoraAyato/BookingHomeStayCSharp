</div>

@section Scripts {
    <style>
        .animate-spin {
            animation: spin 1s linear infinite;
        }

        @@keyframes spin {
            0% {
                transform: rotate(0deg);
            }

            100% {
                transform: rotate(360deg);
            }
        }
    </style>
    <script>
        // Global variables to store profile and booking data
        let profileInfo = null;
        let bookingData = null;
         let currentPage = 1;
        // Fetch profile information
        async function fetchProfileInfo() {
            document.getElementById('pageLoading').classList.remove('hidden');
            try {
                const response = await fetch('/User/GetProfile');
                const data = await response.json();
                if (data.success) {
                    profileInfo = data.data;
                    updateProfileUI();
                } else {
                    showNotification('error', data.message || 'Không thể tải dữ liệu hồ sơ.');
                }
            } catch (error) {
                showNotification('error', 'Lỗi khi tải dữ liệu: ' + error.message);
              
            } finally {
                document.getElementById('pageLoading').classList.add('hidden');
            }
        }

        // Fetch booking data
        async function fetchMyBookings(pageNumber = 1) {
            document.getElementById('pageLoading').classList.remove('hidden');
            try {
                const response = await fetch(`/User/GetMyBooking?pageNumber=${pageNumber}`);
                const data = await response.json();
                if (data.success) {
                    bookingData = data.data;
              
                    updateBookingsUI();
                    updatePaginationUI(pageNumber, data.data.TotalPages);
                } else {
                    showNotification('error', data.message || 'Không thể tải danh sách đặt phòng.');
                }
            } catch (error) {
                showNotification('error', 'Lỗi khi tải dữ liệu: ' + error.message);
              
            } finally {
                document.getElementById('pageLoading').classList.add('hidden');
            }
        }

        // Update Profile UI
        function updateProfileUI() {
            if (!profileInfo) return;

            // Sidebar
            document.getElementById('profileFullName').textContent = profileInfo.fullName || 'Chưa cung cấp';
            document.getElementById('profileEmail').textContent = profileInfo.email || '';
            document.getElementById('profilePhoneNumber').textContent = profileInfo.phoneNumber || 'Chưa cung cấp';
            const trangThaiSpan = document.getElementById('profileTrangThai');
            trangThaiSpan.textContent = profileInfo.trangThai || 'Không xác định';
            trangThaiSpan.className = 'inline-flex items-center px-3 py-1 rounded-full text-sm font-medium ' +
                (profileInfo.trangThai === 'Hoạt động' ? 'bg-green-100 text-green-800' :
                 profileInfo.trangThai === 'Khóa' ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800');
            document.getElementById('profileTichDiem').textContent = profileInfo.tichDiem;
            document.getElementById('profileImagePreview').src = profileInfo.profilePicture || '/img/default-avatar.jpg';
            document.getElementById('reviewerAvatar').src = profileInfo.profilePicture || '/img/default-avatar.jpg';
            document.getElementById('reviewerName').textContent = profileInfo.fullName || 'Người dùng';

            // Profile Tab
            document.getElementById('infoFullName').textContent = profileInfo.fullName || 'Chưa cung cấp';
            document.getElementById('infoEmail').textContent = profileInfo.email || '';
            document.getElementById('infoPhoneNumber').textContent = profileInfo.phoneNumber || 'Chưa cung cấp';
            document.getElementById('infoDateOfBirth').textContent = profileInfo.dateOfBirth ? new Date(profileInfo.dateOfBirth).toLocaleDateString('vi-VN') : 'Chưa cung cấp';
            document.getElementById('infoAddress').textContent = profileInfo.address || 'Chưa cung cấp';

            // Update Profile Modal
            document.getElementById('modalEmail').textContent = profileInfo.email || '';
            document.getElementById('otpEmail').textContent = profileInfo.email || '';
        }

        // Update Bookings UI
            function updateBookingsUI() {
            const bookingsList = document.getElementById('bookingsList');
            const totalBookings = document.getElementById('totalBookings');
            bookingsList.innerHTML = '';

            // Kiểm tra PhieuDatPhongs từ MyBookingDTO
            const phieuDatPhongs = bookingData.PhieuDatPhongs || [];
            totalBookings.textContent = phieuDatPhongs.length;

            if (phieuDatPhongs.length === 0) {
                bookingsList.innerHTML = `
                    <div class="text-center py-12">
                        <i class="fas fa-calendar-times text-4xl text-gray-300 mb-4"></i>
                        <p class="text-gray-500 text-lg">Bạn chưa có phiếu đặt phòng nào.</p>
                        <a href="/homestay" class="mt-4 inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-rose-600 hover:bg-rose-700">
                            Đặt phòng ngay <i class="fas fa-arrow-right ml-2"></i>
                        </a>
                    </div>`;
                return;
            }

            phieuDatPhongs.forEach(phieu => {
                // Kiểm tra dữ liệu phiếu
                if (!phieu || !phieu.maPDPhong) return;

                const statusClass = phieu.trangThai === 'Đã xác nhận' ? 'bg-green-100 text-green-800' :
                                   phieu.trangThai === 'Chờ xác nhận' ? 'bg-yellow-100 text-yellow-800' :
                                   phieu.trangThai === 'Hoàn thành' ? 'bg-blue-100 text-blue-800' : 'bg-red-100 text-red-800';

                let buttons = `
                    <button onclick="showBookingDetails('${phieu.maPDPhong}')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                        <i class="fas fa-info-circle mr-1"></i> Chi tiết
                    </button>`;
                if (phieu.trangThai === 'Đã xác nhận') {
                    buttons += `
                        <button onclick="showCancelBookingModal('${phieu.maPDPhong}')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            <i class="fas fa-times-circle mr-1"></i> Hủy
                        </button>
                        <button onclick="showAddServiceModal('${phieu.maPDPhong}')" class="inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50">
                            <i class="fas fa-plus-circle mr-1"></i> Thêm dịch vụ
                        </button>`;
                }
                if (phieu.trangThai === 'Hoàn thành') {
                    buttons += `
                        <button onclick="showReviewModal('${phieu.maPDPhong}')" class="review-button inline-flex items-center px-3 py-1 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50" data-ma-pdphong="${phieu.maPDPhong}">
                            <i class="fas fa-star mr-1"></i> <span class="review-text">Đánh giá</span>
                        </button>`;
                }

                let chiTietHtml = '';
                if (Array.isArray(phieu.chiTietDatPhongs) && phieu.chiTietDatPhongs.length > 0) {
                    chiTietHtml = phieu.chiTietDatPhongs.map(chiTiet => {
                        // Kiểm tra chiTiet và Phong
                        if (!chiTiet || !chiTiet.Phong) return '';

                        const ngayDen = chiTiet.NgayDen ? new Date(chiTiet.NgayDen).toLocaleDateString('vi-VN') : 'N/A';
                        const ngayDi = chiTiet.NgayDi ? new Date(chiTiet.NgayDi).toLocaleDateString('vi-VN') : 'N/A';

                        return `
                            <li class="flex items-start">
                                <div class="flex-shrink-0 h-16 w-16 rounded-md overflow-hidden">
                                    <img class="h-full w-full object-cover" src="${chiTiet.Phong.HinhAnhPhongs?.find(s => s?.LaAnhChinh)?.UrlAnh || '/img/default-room.jpg'}" alt="${chiTiet.Phong.TenPhong || 'Phòng'}">
                                </div>
                                <div class="ml-3">
                                    <p class="text-sm font-medium text-gray-900">${chiTiet.Phong.TenPhong || 'N/A'} - ${chiTiet.Phong.Homestay?.TenHomestay || 'N/A'}</p>
                                    <p class="text-sm text-gray-500">
                                        <i class="far fa-calendar mr-1"></i> ${ngayDen} - ${ngayDi}
                                    </p>
                                </div>
                            </li>`;
                    }).filter(Boolean).join('');
                    chiTietHtml = chiTietHtml ? `<ul class="space-y-3">${chiTietHtml}</ul>` : '<p class="text-sm text-gray-500">Không có chi tiết phòng</p>';
                } else {
                    chiTietHtml = '<p class="text-sm text-gray-500">Không có chi tiết phòng</p>';
                }

                bookingsList.innerHTML += `
                    <div class="border border-gray-200 rounded-lg overflow-hidden hover:shadow-md transition-shadow">
                        <div class="p-4 sm:p-6">
                            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start">
                                <div class="flex-1">
                                    <div class="flex items-center space-x-3">
                                        <span class="text-sm font-medium text-gray-900">Mã phiếu: ${phieu.maPDPhong}</span>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusClass}">
                                            ${phieu.trangThai || 'N/A'}
                                        </span>
                                    </div>
                                    <p class="mt-1 text-sm text-gray-500">
                                        <i class="far fa-calendar-alt mr-1"></i> Ngày lập: ${phieu.ngayLap ? new Date(phieu.ngayLap).toLocaleDateString('vi-VN') : 'N/A'}
                                    </p>
                                </div>
                                <div class="mt-3 sm:mt-0 flex space-x-2 flex-wrap gap-2">
                                    ${buttons}
                                </div>
                            </div>
                            <div class="mt-4 border-t border-gray-200 pt-4">
                                <h4 class="text-sm font-medium text-gray-900 mb-2">Chi tiết phòng</h4>
                                ${chiTietHtml}
                            </div>
                        </div>
                    </div>`;
            });

            // Initialize review buttons
            document.querySelectorAll('.review-button').forEach(button => {
                const maPDPhong = button.getAttribute('data-ma-pdphong');
                fetch(`/User/CheckReview?maPDPhong=${maPDPhong}`)
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.hasReview) {
                            button.querySelector('.review-text').textContent = 'Xem đánh giá';
                        }
                    })
                    .catch(error => console.error('Lỗi khi kiểm tra đánh giá:', error));
            });
        }

        // Update Pagination UI
        function updatePaginationUI(currentPage, totalPages) {
            const pagination = document.getElementById('pagination');
            if (totalPages <= 1) {
                pagination.classList.add('hidden');
                return;
            }
            pagination.classList.remove('hidden');
            let paginationHtml = `
                <div class="flex-1 flex justify-between sm:hidden">
                    <button onclick="fetchMyBookings(${currentPage - 1})" class="relative inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 ${currentPage === 1 ? 'pointer-events-none opacity-50' : ''}">
                        Trước
                    </button>

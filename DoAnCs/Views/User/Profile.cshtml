        // Update Profile Modal
         
        let initialFormState = {};

        function showUpdateProfileModal() {
            if (profileInfo) {
                document.getElementById('FullName').value = profileInfo.fullName || '';
                document.getElementById('PhoneNumber').value = profileInfo.phoneNumber || '';
                document.getElementById('DateOfBirth').value = profileInfo.dateOfBirth ? new Date(profileInfo.dateOfBirth).toISOString().split('T')[0] : '';
                document.getElementById('Address').value = profileInfo.address || '';

                // Lưu trạng thái ban đầu
                initialFormState = {
                    FullName: profileInfo.fullName || '',
                    PhoneNumber: profileInfo.phoneNumber || '',
                    DateOfBirth: profileInfo.dateOfBirth ? new Date(profileInfo.dateOfBirth).toISOString().split('T')[0] : '',
                    Address: profileInfo.address || ''
                };
            }
            document.getElementById('updateProfileModal').classList.remove('hidden');

            // Kiểm tra tuổi khi mở modal (nếu có DateOfBirth)
            const dateOfBirthInput = document.getElementById('DateOfBirth');
            if (dateOfBirthInput.value) {
                checkAge(dateOfBirthInput.value);
            }

            // Ẩn nút submit ban đầu vì chưa có thay đổi
            toggleSubmitButton();
        }

        // Hàm tính tuổi và kiểm tra
        function checkAge(dateOfBirth) {
            const birthDate = new Date(dateOfBirth);
            const today = new Date();
            let age = today.getFullYear() - birthDate.getFullYear();
            const monthDiff = today.getMonth() - birthDate.getMonth();

            if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                age--;
            }

            const dateOfBirthError = document.getElementById('DateOfBirthError');
            if (age < 18) {
                dateOfBirthError.textContent = 'Bạn phải từ 18 tuổi trở lên.';
                dateOfBirthError.classList.remove('hidden');
            } else {
                dateOfBirthError.classList.add('hidden');
            }
        }

        // Sự kiện thay đổi ngày sinh để kiểm tra tuổi realtime
        document.getElementById('DateOfBirth').addEventListener('change', function () {
            checkAge(this.value);
            toggleSubmitButton();
        });

        // Theo dõi thay đổi trên các input
        ['FullName', 'PhoneNumber', 'DateOfBirth', 'Address'].forEach(id => {
            document.getElementById(id).addEventListener('input', toggleSubmitButton);
        });

        // Hàm kiểm tra và hiển thị/ẩn nút submit
        function toggleSubmitButton() {
            const currentFormState = {
                FullName: document.getElementById('FullName').value,
                PhoneNumber: document.getElementById('PhoneNumber').value,
                DateOfBirth: document.getElementById('DateOfBirth').value,
                Address: document.getElementById('Address').value
            };

            const hasChanges = Object.keys(initialFormState).some(key => {
                return initialFormState[key] !== currentFormState[key];
            });

            const submitButton = document.getElementById('submitButton');
            if (hasChanges) {
                submitButton.classList.remove('hidden');
            } else {
                submitButton.classList.add('hidden');
            }
        }

        document.getElementById('profileForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const submitButton = document.getElementById('submitButton');
            const submitText = document.getElementById('submitText');
            const submitSpinner = document.getElementById('submitSpinner');

            submitButton.disabled = true;
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            const formData = new FormData(this);
            const fullName = formData.get('FullName');
            const phoneNumber = formData.get('PhoneNumber');
            const dateOfBirth = formData.get('DateOfBirth');

            // Ẩn tất cả thông báo lỗi trước khi kiểm tra
            document.getElementById('FullNameError').textContent = '';
            document.getElementById('PhoneNumberError').textContent = '';
            document.getElementById('DateOfBirthError').textContent = '';

            let hasError = false;

            // Validation cho FullName
            if (!fullName || fullName.trim().length === 0) {
                document.getElementById('FullNameError').textContent = 'Họ và tên không được để trống';
                hasError = true;
            }

            // Validation cho PhoneNumber
            if (!phoneNumber || !/^\d{10,11}$/.test(phoneNumber)) {
                document.getElementById('PhoneNumberError').textContent = 'Số điện thoại phải có 10-11 chữ số';
                hasError = true;
            }

            // Validation cho DateOfBirth (tuổi >= 18)
            if (dateOfBirth) {
                const birthDate = new Date(dateOfBirth);
                const today = new Date();
                let age = today.getFullYear() - birthDate.getFullYear();
                const monthDiff = today.getMonth() - birthDate.getMonth();

                if (monthDiff < 0 || (monthDiff === 0 && today.getDate() < birthDate.getDate())) {
                    age--;
                }

                if (age < 18) {
                    document.getElementById('DateOfBirthError').textContent = 'Bạn phải từ 18 tuổi trở lên.';
                    hasError = true;
                }
            } else {
                document.getElementById('DateOfBirthError').textContent = 'Ngày sinh không được để trống.';
                hasError = true;
            }

            if (hasError) {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
                return;
            }

            fetch('/User/UpdateProfile', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('success', 'Cập nhật thông tin thành công.');
                    profileInfo.fullName = formData.get('FullName');
                    profileInfo.phoneNumber = formData.get('PhoneNumber');
                    profileInfo.dateOfBirth = formData.get('DateOfBirth');
                    profileInfo.address = formData.get('Address');
                    updateProfileUI();
                    closeModal('updateProfileModal');
                } else {
                    showNotification('error', data.message || 'Không thể cập nhật thông tin.');
                }
            })
            .catch(error => {
                showNotification('error', 'Lỗi khi cập nhật: ' + error.message);
                console.error(error);
            })
            .finally(() => {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
            });
        });


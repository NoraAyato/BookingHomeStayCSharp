                                statusHtml = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800"><i class="fas fa-times-circle mr-1"></i> ${data.data.trangThai}</span>`;
                        }
                        document.getElementById('modalTrangThai').innerHTML = statusHtml;

                        document.getElementById('modalTongTien').textContent = data.data.tongTien
                            ? new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(data.data.tongTien)
                            : 'Chưa có thông tin';

                        // Gán dữ liệu chi tiết phòng vào biến toàn cục để phân trang
                        chiTietPhongsGlobal = data.data.chiTietPhongs || [];
                        currentPage = 1;

                        renderChiTietPhongsPage();
                        document.getElementById('bookingDetailsModal').classList.remove('hidden');
                    } else {
                        showNotification('error', data.message || 'Không thể tải chi tiết phiếu đặt phòng.');
                    }
                })
                .catch(error => {
                    showNotification('error', 'Lỗi khi tải chi tiết: ' + error.message);
                    console.error(error);
                });
        }

        function renderChiTietPhongsPage() {
            const chiTietPhongsDiv = document.getElementById('modalChiTietPhongs');
            chiTietPhongsDiv.innerHTML = '';

            const start = (currentPage - 1) * pageSize;
            const end = start + pageSize;
            const currentItems = chiTietPhongsGlobal.slice(start, end);

            if (currentItems.length === 0) {
                chiTietPhongsDiv.innerHTML = '<p class="text-sm text-gray-500">Không có chi tiết phòng.</p>';
                return;
            }

            currentItems.forEach(ct => {
                let dichVuHtml = Array.isArray(ct.dichVus) && ct.dichVus.length > 0 ? `
                    <div class="mt-3">
                        <p class="text-sm font-medium text-gray-700 mb-1">Dịch vụ đã sử dụng:</p>
                        <div class="bg-gray-50 rounded-md p-3">
                            <table class="min-w-full divide-y divide-gray-200">
                                <thead class="bg-gray-100">
                                    <tr>
                                        <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Dịch vụ</th>
                                        <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Số lượng</th>
                                        <th class="px-3 py-2 text-left text-xs font-medium text-gray-500 uppercase">Đơn giá</th>
                                    </tr>
                                </thead>
                                <tbody class="bg-white divide-y-activator">
                                    ${ct.dichVus.map(dv => `
                                        <tr>
                                            <td class="px-3 py-2 text-sm text-gray-900">${dv.tenDV}</td>
                                            <td class="px-3 py-2 text-sm text-gray-500">${dv.soLuong}</td>
                                            <td class="px-3 py-2 text-sm text-gray-500">${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(dv.donGia)}</td>
                                        </tr>`).join('')}
                                </tbody>
                            </table>
                        </div>
                    </div>` : '<p class="text-sm text-gray-500 mt-2">Không có dịch vụ nào được sử dụng.</p>';

                chiTietPhongsDiv.innerHTML += `
                    <div class="border border-gray-200 rounded-lg p-4 mb-4">
                        <div class="flex items-start">
                            <div class="flex-shrink-0 h-20 w-20 rounded-md overflow-hidden">
                                <img class="h-full w-full object-cover" src="${ct.hinhAnhChinh || '/img/default-room.jpg'}" alt="${ct.tenPhong}">
                            </div>
                            <div class="ml-4 flex-1">
                                <p class="text-sm font-medium text-gray-900">${ct.tenPhong} - ${ct.tenHomestay}</p>
                                <p class="text-sm text-gray-500">
                                    <i class="far fa-calendar mr-1"></i> ${ct.ngayDen} - ${ct.ngayDi}
                                </p>
                                ${dichVuHtml}
                            </div>
                        </div>
                    </div>`;
            });

            // Phân trang
            const totalPages = Math.ceil(chiTietPhongsGlobal.length / pageSize);
            if (totalPages > 1) {
                chiTietPhongsDiv.innerHTML += `
                    <div class="flex justify-between items-center mt-2">
                        <button onclick="changePage(-1)" class="px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded" ${currentPage === 1 ? 'disabled' : ''}>Trước</button>
                        <span class="text-sm text-gray-600">Trang ${currentPage} / ${totalPages}</span>
                        <button onclick="changePage(1)" class="px-3 py-1 text-sm bg-gray-100 hover:bg-gray-200 rounded" ${currentPage === totalPages ? 'disabled' : ''}>Sau</button>
                    </div>`;
            }
        }

        function changePage(delta) {
            const totalPages = Math.ceil(chiTietPhongsGlobal.length / pageSize);
            currentPage += delta;
            if (currentPage < 1) currentPage = 1;
            if (currentPage > totalPages) currentPage = totalPages;
            renderChiTietPhongsPage();
        }



           document.getElementById('addServiceForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const submitButton = document.getElementById('submitServiceButton');
            const submitText = document.getElementById('submitServiceText');
            const submitSpinner = document.getElementById('submitServiceSpinner');

            submitButton.disabled = true;
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            const maPDPhong = document.getElementById('addServiceMaPDPhong').textContent;
            const roomIds = Array.from(document.getElementsByName('roomIds')).map(input => input.value);
            const serviceIds = Array.from(document.getElementsByName('serviceIds')).map(input => input.value);
            const quantities = Array.from(document.getElementsByName('quantities')).map(input => {
                const value = parseInt(input.value);
                return isNaN(value) || value <= 0 ? 1 : value;
            });

            let hasError = false;
            document.getElementById('roomError').classList.add('hidden');
            document.getElementById('serviceError').classList.add('hidden');

            if (roomIds.length === 0) {
                document.getElementById('roomError').textContent = 'Không có phòng nào được chọn.';
                document.getElementById('roomError').classList.remove('hidden');
                hasError = true;
            }

            if (serviceIds.every(id => id === '')) {
                document.getElementById('serviceError').textContent = 'Vui lòng chọn ít nhất một dịch vụ.';
                document.getElementById('serviceError').classList.remove('hidden');
                hasError = true;
            }

            if (quantities.some(q => q <= 0)) {
                document.getElementById('serviceError').textContent = 'Số lượng dịch vụ phải lớn hơn 0.';
                document.getElementById('serviceError').classList.remove('hidden');
                hasError = true;
            }

            if (hasError) {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
                return;
            }

            const rawData = roomIds.map((roomId, index) => ({
                maPhong: roomId,
                maDV: serviceIds[index] || null,
                soLuong: quantities[index]
            })).filter(item => item.maDV && item.soLuong > 0);

            const groupedData = {};
            rawData.forEach(item => {
                if (!groupedData[item.maPhong]) {
                    groupedData[item.maPhong] = [];
                }
                groupedData[item.maPhong].push({
                    maDv: item.maDV,
                    soLuong: item.soLuong
                });
            });

            const finalData = {
                maPDPhong: maPDPhong,
                rooms: Object.entries(groupedData).map(([maPhong, services]) => ({
                    maPhong,
                    services
                }))
            };

          

            fetch(`/User/AddService`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(finalData)
            })
                .then(response => response.json())
                .then(data => {
                
                    if (data.success) {
                        showNotification('success', 'Thêm dịch vụ thành công.');
                        closeModal('addServiceModal');
                         fetchMyBookings(currentPage);
                    } else {
                        showNotification('error', data.message || 'Không thể thêm dịch vụ.');
                    }
                })
                .catch(error => {
                    showNotification('error', 'Lỗi khi thêm dịch vụ: ' + error.message);
                    console.error(error);
                })
                .finally(() => {
                    submitButton.disabled = false;
                    submitText.classList.remove('hidden');
                    submitSpinner.classList.add('hidden');
                });
        });


        // Cancel Booking Modal
        function showCancelBookingModal(maPDPhong) {
            document.getElementById('cancelMaPDPhong').value = maPDPhong;
            document.getElementById('cancelBookingModal').classList.remove('hidden');
        }

                document.getElementById('cancelBookingForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const submitButton = document.getElementById('submitCancelButton');
            const submitText = document.getElementById('submitCancelText');
            const submitSpinner = document.getElementById('submitCancelSpinner');

            submitButton.disabled = true;
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            // Thu thập dữ liệu từ form
            const maPDPhong = document.getElementById('cancelMaPDPhong')?.value || null;
            const tenNganHang = document.getElementById('TenNganHang')?.value || null;
            const soTaiKhoan = document.getElementById('SoTaiKhoan')?.value || null;
            const lyDo = document.getElementById('LyDo')?.value || null; // Nếu form có input lý do

            // Ẩn thông báo lỗi
            document.getElementById('tenNganHangError').classList.add('hidden');
            document.getElementById('soTaiKhoanError').classList.add('hidden');

            // Validation
            let hasError = false;
            if (tenNganHang && !soTaiKhoan) {
                document.getElementById('soTaiKhoanError').textContent = 'Vui lòng nhập số tài khoản nếu đã cung cấp tên ngân hàng.';
                document.getElementById('soTaiKhoanError').classList.remove('hidden');
                hasError = true;
            }
            if (soTaiKhoan && !tenNganHang) {
                document.getElementById('tenNganHangError').textContent = 'Vui lòng nhập tên ngân hàng nếu đã cung cấp số tài khoản.';
                document.getElementById('tenNganHangError').classList.remove('hidden');
                hasError = true;
            }
            if (soTaiKhoan && !/^\d+$/.test(soTaiKhoan)) {
                document.getElementById('soTaiKhoanError').textContent = 'Số tài khoản chỉ được chứa các chữ số.';
                document.getElementById('soTaiKhoanError').classList.remove('hidden');
                hasError = true;
            }
            if (tenNganHang && tenNganHang.length > 100) {
                document.getElementById('tenNganHangError').textContent = 'Tên ngân hàng không được vượt quá 100 ký tự.';
                document.getElementById('tenNganHangError').classList.remove('hidden');
                hasError = true;
            }
            if (soTaiKhoan && soTaiKhoan.length > 50) {
                document.getElementById('soTaiKhoanError').textContent = 'Số tài khoản không được vượt quá 50 ký tự.';
                document.getElementById('soTaiKhoanError').classList.remove('hidden');
                hasError = true;
            }
            if (!maPDPhong) {
                showNotification('error', 'Không tìm thấy mã phiếu đặt phòng.');
                hasError = true;
            }

            if (hasError) {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
                return;
            }

            // Tạo object dữ liệu để gửi
            const data = {
                MaPDPhong: maPDPhong,
                TenNganHang: tenNganHang,
                SoTaiKhoan: soTaiKhoan,
                LyDo: lyDo
            };

       

            // Gửi request dưới dạng JSON
            fetch('/User/CancelBooking', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                },
                body: JSON.stringify(data)
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
               
                if (data.success) {
                    showNotification('success', 'Hủy phiếu đặt phòng thành công.');
                    closeModal('cancelBookingModal');
                    fetchMyBookings();
                } else {
                    showNotification('error', data.message || 'Không thể hủy phiếu đặt phòng.');
                }
            })
            .catch(error => {
                console.error('Error details:', error);
                showNotification('error', 'Lỗi khi hủy phiếu: ' + error.message);
            })
            .finally(() => {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
            });
        });

        // Review Modal
                function showReviewModal(maPDPhong) {
            fetch(`/User/CheckReview?maPDPhong=${maPDPhong}`)
                .then(response => response.json())
                .then(data => {
                    document.getElementById('reviewMaPDPhong').value = maPDPhong;
                    document.getElementById('reviewModal').classList.remove('hidden');

                    if (data.success && data.hasReview) {
                        // Show existing review
                        document.getElementById('addReviewFormContainer').classList.add('hidden');
                        document.getElementById('viewReviewContent').classList.remove('hidden');
                        document.getElementById('review-modal-title').textContent = 'Xem đánh giá';

                        fetch(`/User/GetReviews?maPDPhong=${maPDPhong}`)
                            .then(response => response.json())
                            .then(reviewData => {
                                if (reviewData.success) {
                                    const review = reviewData.danhGiaDto; // Truy cập đúng thuộc tính từ JSON
                                    document.getElementById('reviewerName').textContent = review.tenNguoiDung || profileInfo.fullName || 'Người dùng';
                                    document.getElementById('reviewComment').textContent = review.binhLuan || 'Không có bình luận';
                                    document.getElementById('reviewDate').textContent = review.NgayDanhGia;

                                    const starsContainer = document.getElementById('reviewStars');
                                    starsContainer.innerHTML = '';
                                    for (let i = 1; i <= 5; i++) {
                                        starsContainer.innerHTML += `<i class="fas fa-star ${i <= review.rating ? 'text-yellow-400' : 'text-gray-300'}"></i>`;
                                    }

                                    const imagesContainer = document.getElementById('reviewImages');
                                    imagesContainer.innerHTML = '';
                                    if (review.hinhAnh) {
                                        imagesContainer.innerHTML += `
                                            <a href="${review.hinhAnh}" target="_blank">
                                                <img src="${review.hinhAnh}" alt="Hình ảnh đánh giá" class="h-24 w-24 object-cover rounded-md">
                                            </a>`;
                                    } else {
                                        imagesContainer.innerHTML = '<p class="text-sm text-gray-500">Không có hình ảnh.</p>';
                                    }
                                } else {
                                    showNotification('error', reviewData.message || 'Không thể tải đánh giá.');
                                }
                            })
                            .catch(error => {
                                showNotification('error', 'Lỗi khi tải đánh giá: ' + error.message);
                                console.error(error);
                            });
                    } else {
                        // Show add review form
                        document.getElementById('addReviewFormContainer').classList.remove('hidden');
                        document.getElementById('viewReviewContent').classList.add('hidden');
                        document.getElementById('review-modal-title').textContent = 'Đánh giá phiếu đặt phòng';
                    }
                })
                .catch(error => {
                    showNotification('error', 'Lỗi khi kiểm tra đánh giá: ' + error.message);
                    console.error(error);
                });
        }

        function setRating(rating) {
            document.getElementById('rating').value = rating;
            updateRatingStars(rating);
            const ratingText = {
                1: 'Tệ',
                2: 'Kém',
                3: 'Trung bình',
                4: 'Tốt',
                5: 'Tuyệt vời'
            };
            document.getElementById('rating-text').textContent = ratingText[rating];
        }

        function updateRatingStars(rating) {
            document.querySelectorAll('.rating-star').forEach(star => {
                const starRating = parseInt(star.getAttribute('data-rating'));
                if (starRating <= rating) {
                    star.classList.remove('far');
                    star.classList.add('fas', 'text-yellow-400');
                } else {
                    star.classList.add('far');
                    star.classList.remove('fas', 'text-yellow-400');
                }
            });
        }

        function setComment(comment) {
            document.getElementById('binhLuan').value = comment;
        }

        function previewImages(input) {
            const previewContainer = document.getElementById('imagePreviewContainer');
            previewContainer.innerHTML = '';
            const files = input.files;

            if (files.length > 3) {
                document.getElementById('hinhAnhError').textContent = 'Bạn chỉ có thể tải lên tối đa 3 hình ảnh.';
                document.getElementById('hinhAnhError').classList.remove('hidden');
                input.value = '';
                return;
            }

            document.getElementById('hinhAnhError').classList.add('hidden');

            Array.from(files).forEach(file => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'h-24 w-24 object-cover rounded-md';
                    previewContainer.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }

           document.getElementById('addReviewForm').addEventListener('submit', function (e) {
            e.preventDefault();

            const submitButton = document.getElementById('submitReviewButton');
            const submitText = document.getElementById('submitReviewText');
            const submitSpinner = document.getElementById('submitReviewSpinner');

            // Vô hiệu hóa nút submit và hiển thị spinner
            submitButton.disabled = true;
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            // Lấy dữ liệu từ form
            const formData = new FormData(this);
            const rating = formData.get('Rating');
            const binhLuan = formData.get('BinhLuan');
            const hinhAnh = document.getElementById('hinhAnh').files;

            // Ẩn tất cả thông báo lỗi trước khi kiểm tra
            document.getElementById('ratingError').classList.add('hidden');
            document.getElementById('hinhAnhError').classList.add('hidden');
            document.getElementById('binhLuanError').classList.add('hidden');

            let hasError = false;

            // Validation cho Rating
            if (!rating || isNaN(rating) || rating < 1 || rating > 5) {
                document.getElementById('ratingError').textContent = 'Vui lòng chọn điểm đánh giá từ 1 đến 5.';
                document.getElementById('ratingError').classList.remove('hidden');
                hasError = true;
            }

            // Validation cho Bình luận
            if (!binhLuan || binhLuan.trim().length === 0) {
                document.getElementById('binhLuanError').textContent = 'Bình luận không được để trống.';
                document.getElementById('binhLuanError').classList.remove('hidden');
                hasError = true;
            } else if (binhLuan.length > 500) {
                document.getElementById('binhLuanError').textContent = 'Bình luận không được vượt quá 500 ký tự.';
                document.getElementById('binhLuanError').classList.remove('hidden');
                hasError = true;
            }

            // Validation cho Hình ảnh
            if (hinhAnh.length > 3) {
                document.getElementById('hinhAnhError').textContent = 'Bạn chỉ có thể tải lên tối đa 3 hình ảnh.';
                document.getElementById('hinhAnhError').classList.remove('hidden');
                hasError = true;
            }

            // Nếu có lỗi, dừng lại và khôi phục trạng thái nút submit
            if (hasError) {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
                return;
            }

            // Gửi request nếu không có lỗi
            fetch('/User/AddReview', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status}`);
                }
                return response.json();
            })
            .then(data => {
                if (data.success) {
                    showNotification('success', 'Gửi đánh giá thành công.');
                    closeModal('reviewModal');
                    fetchMyBookings();
                } else {
                    showNotification('error', data.message || 'Không thể gửi đánh giá.');
                }
            })
            .catch(error => {
                showNotification('error', 'Lỗi khi gửi đánh giá: ' + error.message);
                console.error(error);
            })
            .finally(() => {
                submitButton.disabled = false;
                submitText.classList.remove('hidden');
                submitSpinner.classList.add('hidden');
            });
        });

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            fetchProfileInfo();
            setRating(5); // Default rating
        });
    </script>

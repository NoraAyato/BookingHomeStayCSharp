@using DoAnCs.Models.ViewModels
@model IEnumerable<PromotionViewModel>
@{
    ViewData["Title"] = "Khuyến mãi khả dụng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="min-h-screen bg-gray-50 py-12 px-4 sm:px-6 lg:px-8">
    <!-- Notification Center -->
    <div id="notification" class="fixed top-4 right-4 z-50 hidden">
        <div class="px-6 py-4 rounded-lg shadow-lg border-l-4 bg-white max-w-sm">
            <div class="flex items-center">
                <div id="notification-icon"></div>
                <div class="ml-3">
                    <p id="notification-message" class="text-sm"></p>
                </div>
                <button onclick="hideNotification()" class="ml-auto text-gray-400 hover:text-gray-500">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="max-w-4xl mx-auto">
        <!-- Header section -->
        <div class="text-center mb-10">
            <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
                Khuyến mãi khả dụng
            </h1>
            <p class="mt-3 text-lg text-gray-500">
                Danh sách các ưu đãi và khuyến mãi bạn có thể sử dụng
            </p>
        </div>

        <div class="bg-white shadow rounded-lg overflow-hidden">
            <!-- Promotion content -->
            <div class="px-6 py-4">
                <!-- Filter and search section -->
                <div class="flex flex-col sm:flex-row justify-between items-center mb-6 gap-4">
                    <div class="w-full sm:w-auto">
                        <label for="promotion-filter" class="sr-only">Lọc khuyến mãi</label>
                        <select id="promotion-filter" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-rose-500 focus:ring-rose-500 sm:text-sm">
                            <option value="all">Tất cả khuyến mãi</option>
                            <option value="active">Có thể áp dụng ngay</option>
                            <option value="condition">Yêu cầu điều kiện</option>
                        </select>
                    </div>
                    <div class="w-full sm:w-auto">
                        <label for="promotion-search" class="sr-only">Tìm kiếm</label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-search text-gray-400"></i>
                            </div>
                            <input type="text" id="promotion-search" placeholder="Tìm kiếm khuyến mãi..."
                                   class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-rose-500 focus:border-rose-500 sm:text-sm">
                        </div>
                    </div>
                </div>

                <!-- Promotion cards -->
                <div class="space-y-4" id="promotions-container">
                    <!-- Promotions will be populated via AJAX -->
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const promotionUrl = '@Url.Action("GetAvailablePromotions", "User", new { area = "" })';
        const applyPromotionUrl = '@Url.Action("ApplyPromotion", "User", new { area = "" })';

        // Notification system
        function showNotification(type, message) {
            const notification = document.getElementById('notification');
            const icon = document.getElementById('notification-icon');
            const msg = document.getElementById('notification-message');

            notification.className = 'fixed top-4 right-4 z-50 px-6 py-4 rounded-lg shadow-lg border-l-4 bg-white max-w-sm';
            if (type === 'success') {
                notification.classList.add('border-green-500');
                icon.innerHTML = '<i class="fas fa-check-circle text-green-500"></i>';
            } else if (type === 'error') {
                notification.classList.add('border-red-500');
                icon.innerHTML = '<i class="fas fa-times-circle text-red-500"></i>';
            } else {
                notification.classList.add('border-blue-500');
                icon.innerHTML = '<i class="fas fa-info-circle text-blue-500"></i>';
            }

            msg.textContent = message;
            notification.classList.remove('hidden');
            setTimeout(() => {
                notification.classList.add('hidden');
            }, 5000);
        }

        function hideNotification() {
            document.getElementById('notification').classList.add('hidden');
        }

        // Fetch promotions via AJAX
        document.addEventListener('DOMContentLoaded', function () {
            fetchPromotions();

            const filterSelect = document.getElementById('promotion-filter');
            const searchInput = document.getElementById('promotion-search');

            function filterPromotions() {
                const filterValue = filterSelect.value;
                const searchValue = searchInput.value.toLowerCase();
                const promotionCards = document.querySelectorAll('.promotion-card');

                promotionCards.forEach(card => {
                    const matchesFilter = filterValue === 'all' ||
                                         (filterValue === 'active' && card.dataset.type === 'active') ||
                                         (filterValue === 'condition' && card.dataset.type === 'condition');

                    const promotionText = card.textContent.toLowerCase();
                    const matchesSearch = promotionText.includes(searchValue);

                    if (matchesFilter && matchesSearch) {
                        card.classList.remove('hidden');
                    } else {
                        card.classList.add('hidden');
                    }
                });
            }

            filterSelect.addEventListener('change', filterPromotions);
            searchInput.addEventListener('input', filterPromotions);
        });

        function fetchPromotions() {
            fetch(promotionUrl, {
                method: 'GET',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                if (response.status === 401) {
                    window.location.href = '/Account/Login';
                    return;
                }
                if (!response.ok) {
                    throw new Error(`HTTP error! Status: ${response.status} ${response.statusText}`);
                }
                return response.json();
            })
            .then(data => {
                const container = document.getElementById('promotions-container');
                container.innerHTML = '';

                if (!data.success || !data.promotions || data.promotions.length === 0) {
                    container.innerHTML = `
                        <div class="text-center py-8">
                            <i class="fas fa-tag text-4xl text-gray-300 mb-3"></i>
                            <p class="text-gray-500">Hiện không có khuyến mãi nào khả dụng</p>
                            <p class="text-sm text-gray-400 mt-2">Khi có khuyến mãi phù hợp, chúng sẽ xuất hiện tại đây</p>
                        </div>`;
                    return;
                }

                data.promotions.forEach(promotion => {
                    const card = document.createElement('div');
                    card.className = 'border rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-200 promotion-card';
                    card.dataset.type = promotion.dieuKien ? 'condition' : 'active';
                    card.innerHTML = `
                        <div class="flex flex-col md:flex-row">
                            <div class="w-full md:w-1/4 bg-gradient-to-r from-rose-100 to-rose-50 flex items-center justify-center p-4">
                                <div class="text-center">
                                    <i class="fas fa-percentage text-4xl text-rose-500 mb-2"></i>
                                    <span class="text-2xl font-bold text-rose-600">${promotion.chietKhau}${promotion.loaiChietKhau === 'Percentage' ? '%' : ' VND'}</span>
                                </div>
                            </div>
                            <div class="w-full md:w-2/4 p-4">
                                <h3 class="text-lg font-semibold text-gray-900">${promotion.noiDung}</h3>
                                <div class="mt-2 flex items-center text-sm text-gray-500">
                                    <i class="far fa-calendar-alt mr-2"></i>
                                    <span>HSD: ${promotion.hsd}</span>
                                </div>
                                ${promotion.dieuKien ? `
                                    <div class="mt-2 flex items-start text-sm text-amber-600">
                                        <i class="fas fa-info-circle mr-2 mt-0.5"></i>
                                        <span>Điều kiện: ${promotion.dieuKien}</span>
                                    </div>
                                ` : ''}
                                <div class="mt-2 text-sm text-gray-500">
                                    <span>Số lượng còn lại: ${promotion.soLuongConLai}</span>
                                </div>
                            </div>
                            <div class="w-full md:w-1/4 p-4 flex items-center justify-end hidden">
                                <button onclick="selectPromotion('${promotion.maKM}')"
                                        class="px-4 py-2 bg-rose-600 text-white rounded-md hover:bg-rose-700 focus:outline-none focus:ring-2 focus:ring-rose-500 focus:ring-offset-2 transition-colors">
                                    Áp dụng ngay
                                </button>
                            </div>
                        </div>
                    `;
                    container.appendChild(card);
                });
            })
            .catch(error => {
                console.error('Error fetching promotions:', error);
                showNotification('error', 'Lỗi khi tải khuyến mãi: ' + error.message);
            });
        }

    </script>
}
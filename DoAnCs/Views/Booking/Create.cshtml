        // Hàm fetch với retry
        async function fetchWithRetry(url, options, retries = 3) {
            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(url, options);
                    if (!response.ok) throw new Error(`HTTP error! Status: ${response.status}`);
                    return response;
                } catch (error) {
                    if (i === retries - 1) throw error;
                    await new Promise(resolve => setTimeout(resolve, 1000 * (i + 1)));
                }
            }
        }

        // Hàm lấy danh sách khuyến mãi
        async function fetchPromotions(bookingData) {
            console.log('fetchPromotions called with bookingData:', bookingData);
            try {
                if (!bookingData || !bookingData.homestayId || !bookingData.checkInDate || !bookingData.checkOutDate || !bookingData.selectedRooms) {
                    console.error('Invalid bookingData:', bookingData);
                    showToast('Dữ liệu đặt phòng không hợp lệ. Không thể lấy khuyến mãi.', false);
                    return;
                }

                const params = new URLSearchParams({
                    homestayId: bookingData.homestayId,
                    checkInDate: new Date(bookingData.checkInDate).toISOString().split('T')[0],
                    checkOutDate: new Date(bookingData.checkOutDate).toISOString().split('T')[0],
                    selectedRoomIds: bookingData.selectedRooms.map(room => room.maPhong).join(',')
                });
                const url = '@Url.Action("GetAvailablePromotions", "Booking")' + '?' + params.toString();
                console.log('Fetching promotions from URL:', url);

                const response = await fetchWithRetry(url, {
                    method: 'GET',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                    cache: 'no-cache'
                });

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    console.error('Non-JSON response:', text);
                    throw new Error('Phản hồi không phải JSON');
                }

                const result = await response.json();
                console.log('Response data:', result);
                if (result.success) {
                    const promotionSelect = document.getElementById('promotionSelect');
                    promotionSelect.innerHTML = '<option value="">Không áp dụng khuyến mãi</option>';
                    result.data.forEach(promo => {
                        promotionSelect.innerHTML += `
                            <option value="${escapeHtml(promo.maKM)}" data-chiet-khau="${promo.chietKhau}" data-loai-chiet-khau="${promo.loaiChietKhau}">
                                ${escapeHtml(promo.noiDung)} (${promo.chietKhau}${promo.loaiChietKhau === 'Percentage' ? '%' : '₫'}, HSD: ${promo.hsd})
                            </option>
                        `;
                    });
                } else {
                    showToast(result.message || 'Không thể lấy danh sách khuyến mãi.', false);
                }
            } catch (error) {
                console.error('Error fetching promotions:', error);
                showToast(`Lỗi khi lấy khuyến mãi: ${error.message}. Vui lòng thử lại.`, false);
            }
        }

        // Hàm áp dụng khuyến mãi và cập nhật tổng tiền
        async function applyPromotion(maKM, bookingData) {
            if (!maKM) {
                updateTotalAmount(0);
                document.getElementById('promotionMessage').classList.add('hidden');
                return;
            }

            try {
                const formData = new FormData();
                formData.append('maKM', maKM);
                formData.append('homestayId', bookingData.homestayId);
                formData.append('checkInDate', new Date(bookingData.checkInDate).toISOString().split('T')[0]);
                formData.append('checkOutDate', new Date(bookingData.checkOutDate).toISOString().split('T')[0]);
                bookingData.selectedRooms.forEach(room => {
                    formData.append('selectedRoomIds', room.maPhong);
                });
                formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                const response = await fetchWithRetry('@Url.Action("ApplyPromotion", "Booking")', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    console.error('Non-JSON response:', text);
                    throw new Error('Phản hồi không phải JSON');
                }

                const result = await response.json();
                if (result.success) {
                    const { chietKhau, loaiChietKhau } = result.data;
                    const totalRoomPrice = bookingData.selectedRooms.reduce((sum, r) => sum + r.donGia * bookingData.numberOfNights, 0);
                    const totalPhuThu = bookingData.selectedRooms.reduce((sum, r) => sum + r.totalPhuThu, 0);
                    const totalServicePrice = bookingData.selectedRooms.reduce((sum, r) => sum + (r.selectedServices ? r.selectedServices.reduce((s, svc) => s + svc.soLuong * svc.donGia * bookingData.numberOfNights, 0) : 0), 0);
                    const totalAmountBeforeDiscount = totalRoomPrice + totalPhuThu;

                    let discount = 0;
                    if (loaiChietKhau === 'Percentage') {
                        discount = totalAmountBeforeDiscount * (chietKhau / 100);
                    } else if (loaiChietKhau === 'Fixed') {
                        discount = chietKhau;
                    }

                    discount = Math.min(discount, totalAmountBeforeDiscount);

                    updateTotalAmount(discount);
                    document.getElementById('promotionMessage').classList.remove('hidden');
                    document.getElementById('promotionMessage').textContent = `Đã áp dụng khuyến mãi: ${result.data.noiDung} (${chietKhau}${loaiChietKhau === 'Percentage' ? '%' : '₫'})`;
                    document.getElementById('promotionMessage').classList.add('text-green-600');
                } else {
                    showToast(result.message || 'Không thể áp dụng khuyến mãi.', false);
                    document.getElementById('promotionSelect').value = '';
                    updateTotalAmount(0);
                    document.getElementById('promotionMessage').classList.add('hidden');
                }
            } catch (error) {
                console.error('Error applying promotion:', error);
                showToast(`Lỗi: ${error.message}. Vui lòng thử lại.`, false);
                document.getElementById('promotionSelect').value = '';
                updateTotalAmount(0);
                document.getElementById('promotionMessage').classList.add('hidden');
            }
        }

        // Hàm cập nhật tổng tiền trong modal
        function updateTotalAmount(discount) {
            const bookingData = getBookingData();
            const totalRoomPrice = bookingData.selectedRooms.reduce((sum, r) => sum + r.donGia * bookingData.numberOfNights, 0);
            const totalPhuThu = bookingData.selectedRooms.reduce((sum, r) => sum + r.totalPhuThu, 0);
            const totalServicePrice = bookingData.selectedRooms.reduce((sum, r) => sum + (r.selectedServices ? r.selectedServices.reduce((s, svc) => s + svc.soLuong * svc.donGia * bookingData.numberOfNights, 0) : 0), 0);
            const totalAmount = totalRoomPrice + totalPhuThu + totalServicePrice - discount;

            const totalSection = document.querySelector('.total-amount-section .space-y-2');
            totalSection.innerHTML = `
                <div class="flex justify-between">
                    <span class="text-gray-600">Tổng giá phòng:</span>
                    <span class="font-medium">${formatCurrency(totalRoomPrice)}</span>
                </div>
                ${totalPhuThu > 0 ? `
                    <div class="flex justify-between">
                        <span class="text-gray-600">Tổng phụ thu:</span>
                        <span class="font-medium">${formatCurrency(totalPhuThu)}</span>
                    </div>
                ` : ''}
                <div class="flex justify-between">
                    <span class="text-gray-600">Tổng giá dịch vụ:</span>
                    <span class="font-medium">${formatCurrency(totalServicePrice)}</span>
                </div>
                ${discount > 0 ? `
                    <div class="flex justify-between discount-section">
                        <span class="text-gray-600">Chiết khấu:</span>
                        <span class="font-medium text-green-600">${formatCurrency(discount)}</span>
                    </div>
                ` : ''}
                <div class="flex justify-between text-lg font-bold text-rose-600 pt-2 border-t border-gray-200 mt-2">
                    <span>Tổng cộng:</span>
                    <span>${formatCurrency(totalAmount)}</span>
                </div>
            `;
        }

        // Xử lý submit form đặt phòng
        document.getElementById('bookingForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const submitBtn = form.querySelector('button[type="submit"]');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Đang xử lý...';

            const bookingData = getBookingData();
            if (!bookingData.selectedRooms.length) {
                showToast('Vui lòng chọn ít nhất một phòng.', false);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Xác nhận đặt phòng';
                return;
            }

            const errors = [];
            bookingData.selectedRooms.forEach((room, roomIndex) => {
                room.selectedServices.forEach((service, serviceIndex) => {
                    if (service.soLuong < 1) {
                        errors.push(`Số lượng dịch vụ ${service.tenDV} của phòng ${room.tenPhong} phải lớn hơn hoặc bằng 1.`);
                    }
                });
            });

            if (errors.length > 0) {
                showToast(`Vui lòng kiểm tra lại dịch vụ:\n${errors.join('\n')}`, false);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Xác nhận đặt phòng';
                return;
            }

            const formData = new FormData(form);
            formData.set('bookingData', JSON.stringify(bookingData));

            const serviceIds = [];
            const serviceQuantities = [];
            bookingData.selectedRooms.forEach(room => {
                room.selectedServices.forEach(service => {
                    serviceIds.push(service.maDV);
                    serviceQuantities.push(service.soLuong);
                });
            });
            serviceIds.forEach(id => formData.append('serviceIds', id));
            serviceQuantities.forEach(qty => formData.append('serviceQuantities', qty));

            try {
                const response = await fetchWithRetry(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    console.error('Non-JSON response:', text);
                    showToast(`Lỗi server: ${text || 'Không xác định'}. Vui lòng thử lại.`, false);
                    return;
                }

                const result = await response.json();
                if (result.success) {
                    const data = result.data;
                    const confirmContent = document.getElementById('confirmContent');
                    if (renderConfirmContent(data, confirmContent)) {
                        document.getElementById('confirmModal').classList.remove('hidden');
                        fetchPromotions(bookingData);
                    }
                } else {
                    const errorMessage = result.errors ? result.errors.join('\n') : result.message;
                    showToast(errorMessage || 'Đã xảy ra lỗi khi tạo đặt phòng.', false);
                }
            } catch (error) {
                console.error('Error in Create POST:', error);
                showToast(`Lỗi: ${error.message}. Vui lòng thử lại sau.`, false);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-check-circle mr-2"></i> Xác nhận đặt phòng';
            }
        });

        // Xử lý thay đổi khuyến mãi
        document.getElementById('promotionSelect').addEventListener('change', async (e) => {
            const maKM = e.target.value;
            const bookingData = getBookingData();
            await applyPromotion(maKM, bookingData);
        });

        // Xử lý xác nhận đặt phòng
        document.getElementById('submitConfirm').addEventListener('click', async () => {
            try {
                document.getElementById('submitConfirm').disabled = true;
                const form = document.getElementById('bookingForm');
                const token = form.querySelector('input[name="__RequestVerificationToken"]').value;
                const bookingData = getBookingData();
                const maKM = document.getElementById('promotionSelect').value;

                const formData = new FormData();
                formData.append('__RequestVerificationToken', token);
                formData.append('bookingData', JSON.stringify(bookingData));
                if (maKM) {
                    formData.append('maKM', maKM);
                }

                const response = await fetchWithRetry('@Url.Action("ConfirmBooking", "Booking")', {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    console.error('Non-JSON response:', text);
                    showToast(`Lỗi server: ${text || 'Không xác định'}. Vui lòng thử lại.`, false);
                    return;
                }

                const result = await response.json();

                if (result.success) {
                    showToast('Đặt phòng thành công!', true, () => {
                        const data = result.data;
                        const paymentContent = document.getElementById('paymentContent');
                        if (renderPaymentContent(data, paymentContent)) {
                            document.getElementById('maHD').value = data.maHD;
                            document.getElementById('soTien').value = data.phiDatCoc;
                            document.getElementById('paymentModal').classList.remove('hidden');
                        }
                        document.getElementById('confirmModal').classList.add('hidden');
                    });
                } else {
                    const errorMessage = result.errors ? result.errors.join('\n') : result.message;
                    showToast(errorMessage || 'Không thể xác nhận đặt phòng.', false, () => {
                        document.getElementById('confirmModal').classList.add('hidden');
                    });
                }
            } catch (error) {
                console.error('Error in ConfirmBooking POST:', error);
                showToast(`Lỗi: ${error.message}. Vui lòng thử lại sau.`, false, () => {
                    document.getElementById('confirmModal').classList.add('hidden');
                });
            } finally {
                document.getElementById('submitConfirm').disabled = false;
            }
        });

        // Xử lý thanh toán (Tích hợp MoMo)
                document.getElementById('paymentForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const form = e.target;
            const submitBtn = document.getElementById('submitPayment');
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Đang xử lý...';

            const formData = new FormData(form);
            const maHD = formData.get('maHD');
            const phuongThuc = formData.get('phuongThuc');
            const soTien = parseFloat(formData.get('soTien'));
            const token = formData.get('__RequestVerificationToken');

            console.log('Payment Form Data:', { maHD, phuongThuc, soTien, token });
           
            if (!maHD || !phuongThuc || isNaN(soTien) || soTien <= 0 || !token) {
                showToast('Dữ liệu thanh toán không hợp lệ. Vui lòng kiểm tra lại.', false);
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-wallet mr-2"></i> Thanh toán ngay';
                return;
            }

            try {
                const response = await fetchWithRetry(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                });

                const contentType = response.headers.get('content-type');
                if (!contentType || !contentType.includes('application/json')) {
                    const text = await response.text();
                    console.error('Non-JSON response:', text);
                    showToast(`Lỗi server: ${text || 'Không xác định'}. Vui lòng thử lại.`, false);
                    return;
                }

                const result = await response.json();
                console.log('Payment Response:', result);

                if (result.success) {
                    if (result.redirectUrl) {
                        showToast('Đang chuyển hướng tới MoMo...', true, () => {
                            window.location.href = result.redirectUrl;
                        });
                    } else {
                        showToast('Thanh toán thành công!', true, () => {
                            document.getElementById('paymentModal').classList.add('hidden');
                            window.location.href = '@Url.Action("Index", "Home")';
                        });
                    }
                } else {
                    showToast(result.message || 'Không thể thực hiện thanh toán.', false);
                }
            } catch (error) {
                console.error('Error in ProcessPayment POST:', error);
                showToast(`Lỗi: ${error.message}. Vui lòng thử lại sau.`, false);
            } finally {
                submitBtn.disabled = false;
                submitBtn.innerHTML = '<i class="fas fa-wallet mr-2"></i> Thanh toán ngay';
            }
        });

        // Xử lý nút hủy
        document.getElementById('cancelConfirm').addEventListener('click', () => {
            document.getElementById('confirmModal').classList.add('hidden');
        });

        document.getElementById('cancelConfirmBtn').addEventListener('click', () => {
            document.getElementById('confirmModal').classList.add('hidden');
        });

        document.getElementById('cancelPayment').addEventListener('click', () => {
            document.getElementById('paymentModal').classList.add('hidden');
            window.location.href = '@Url.Action("Index", "Home")';
        });

        document.getElementById('cancelPaymentBtn').addEventListener('click', () => {
            document.getElementById('paymentModal').classList.add('hidden');
            window.location.href = '@Url.Action("Index", "Home")';
        });

        // Xử lý nút "Bỏ chọn"
        document.querySelectorAll('.remove-room-btn').forEach(button => {
            button.addEventListener('click', async (e) => {
                const roomId = button.getAttribute('data-room-id');
                const roomElement = document.getElementById(`room_${roomId}`);

                if (!roomId || !roomElement) {
                    showToast('Không thể xóa phòng. Dữ liệu không hợp lệ.', false);
                    return;
                }

                const confirmRemove = await Swal.fire({
                    title: 'Xác nhận',
                    text: `Bạn có chắc chắn muốn bỏ chọn phòng này không?`,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#f43f5e',
                    cancelButtonColor: '#d1d5db',
                    confirmButtonText: 'Bỏ chọn',
                    cancelButtonText: 'Hủy'
                });

                if (!confirmRemove.isConfirmed) {
                    return;
                }

                try {
                    const url = '@Url.Action("RemoveRoom", "Booking")';
                    const response = await fetchWithRetry(url, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        },
                        body: JSON.stringify(roomId)
                    });

                    const contentType = response.headers.get('content-type');
                    if (!contentType || !contentType.includes('application/json')) {
                        const text = await response.text();
                        console.error('Non-JSON response:', text);
                        throw new Error('Phản hồi không phải JSON');
                    }

                    const result = await response.json();

                    if (result.success) {
                        roomElement.remove();
                        delete originalSelectedServices[roomId];

                        const remainingRooms = document.querySelectorAll('[id^="room_"]');
                        if (remainingRooms.length <= 1) {
                            document.querySelectorAll('.remove-room-btn').forEach(btn => {
                                btn.style.display = 'none';
                            });
                        }

                        if (remainingRooms.length === 0) {
                            const roomList = document.querySelector('.mb-8');
                            const noRoomMessage = document.createElement('div');
                            noRoomMessage.className = 'bg-gray-50 p-6 rounded-lg text-center';
                            noRoomMessage.innerHTML = `
                                <i class="fas fa-bed text-4xl text-gray-300 mb-4"></i>
                                <p class="text-gray-600">Bạn chưa chọn phòng nào</p>
                            `;
                            roomList.appendChild(noRoomMessage);
                        }

                        updateSummary();
                        showToast(result.message || 'Đã bỏ chọn phòng.', true);
                    } else {
                        showToast(result.message || 'Không thể bỏ chọn phòng.', false);
                    }
                } catch (error) {
                    console.error('Error in RemoveRoom:', error);
                    showToast(`Lỗi: ${error.message}. Vui lòng thử lại.`, false);
                }
            });
        });

        // Khởi tạo dữ liệu ban đầu
        saveOriginalServices();
        updateSummary();
    </script>
}
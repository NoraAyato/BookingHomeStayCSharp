@model DoAnCs.Models.ViewModels.BookingViewModel
@{
    ViewData["Title"] = "Đặt phòng";
    var services = ViewBag.Services;
    var selectedRoomIds = ViewBag.SelectedRoomIds as string[] ?? new string[0];
    var numberOfRoom = Model.SelectedRooms.Count;
}

<!-- Thêm SweetAlert2 -->
<link href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>

<section class="py-12 bg-gradient-to-b from-white to-gray-50">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12" data-aos="fade-up">
            <span class="inline-block px-4 py-1 text-sm font-medium rounded-full bg-rose-100 text-rose-600 mb-4">Đặt phòng</span>
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 font-lora mb-4">Đặt phòng tại <span class="text-rose-600">@Model.HomestayName</span></h1>
            <div class="w-24 h-1 bg-rose-500 mx-auto"></div>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="bg-rose-50 border-l-4 border-rose-500 text-rose-700 p-4 rounded-lg mb-8 max-w-4xl mx-auto" role="alert">
                <div class="flex items-center">
                    <i class="fas fa-exclamation-circle mr-2"></i>
                    <p class="font-medium">@TempData["Error"]</p>
                </div>
            </div>
        }

        <div class="flex flex-col lg:flex-row gap-8 max-w-7xl mx-auto">
            <!-- Phần thông tin đặt phòng -->
            <div class="lg:w-2/3">
                <form id="bookingForm" asp-action="Create" asp-controller="Booking" method="post" class="bg-white rounded-2xl shadow-xl p-6">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="bookingData" name="bookingData" />

                    <!-- Thông tin homestay -->
                    <div class="mb-8">
                        <h3 class="text-xl font-semibold text-gray-900 font-lora mb-4 pb-2 border-b border-gray-200">Thông tin homestay</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-600"><i class="fas fa-home text-rose-500 mr-2"></i> <strong>Tên:</strong> @Model.HomestayName</p>
                            </div>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-600"><i class="fas fa-map-marker-alt text-rose-500 mr-2"></i> <strong>Địa chỉ:</strong> @Model.HomestayAddress</p>
                            </div>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-600"><i class="fas fa-calendar-check text-rose-500 mr-2"></i> <strong>Nhận phòng:</strong> @Model.CheckInDate.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-600"><i class="fas fa-calendar-times text-rose-500 mr-2"></i> <strong>Trả phòng:</strong> @Model.CheckOutDate.ToString("dd/MM/yyyy")</p>
                            </div>
                            <div class="bg-gray-50 p-4 rounded-lg">
                                <p class="text-gray-600"><i class="fas fa-moon text-rose-500 mr-2"></i> <strong>Số đêm:</strong> @Model.NumberOfNights</p>
                            </div>
                        </div>
                    </div>

                    <!-- Danh sách phòng đã chọn -->
                    <div class="mb-8">
                        <h3 class="text-xl font-semibold text-gray-900 font-lora mb-4 pb-2 border-b border-gray-200">Phòng đã chọn</h3>

                        @if (!Model.SelectedRooms.Any())
                        {
                            <div class="bg-gray-50 p-6 rounded-lg text-center">
                                <i class="fas fa-bed text-4xl text-gray-300 mb-4"></i>
                                <p class="text-gray-600">Bạn chưa chọn phòng nào</p>
                            </div>
                        }
                        else
                        {
                            @for (int i = 0; i < Model.SelectedRooms.Count; i++)
                            {
                                <div class="border border-gray-200 rounded-xl p-5 mb-6 flex flex-col md:flex-row" id="room_@Model.SelectedRooms[i].MaPhong">
                                    <div class="md:w-1/3 mb-4 md:mb-0">
                                        <img src="@Model.SelectedRooms[i].HinhAnh" alt="@Model.SelectedRooms[i].TenPhong" class="w-full h-48 object-cover rounded-lg shadow-md" />
                                    </div>
                                    <div class="md:w-2/3 md:pl-6">
                                        <input type="hidden" class="room-input" data-ma-phong="@Model.SelectedRooms[i].MaPhong" />
                                        <input type="hidden" class="room-input" data-ten-phong="@Model.SelectedRooms[i].TenPhong" />
                                        <input type="hidden" class="room-input" data-don-gia="@Model.SelectedRooms[i].DonGia.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                        <input type="hidden" class="room-input" data-hinh-anh="@Model.SelectedRooms[i].HinhAnh" />
                                        <input type="hidden" class="room-input" data-total-phu-thu="@Model.SelectedRooms[i].TotalPhuThu.ToString(System.Globalization.CultureInfo.InvariantCulture)" />

                                        <h4 class="text-lg font-medium text-gray-900 mb-2">@Model.SelectedRooms[i].TenPhong</h4>
                                        <div class="my-4">
                                            <p class="text-gray-600 mb-2"><i class="fas fa-tag text-rose-500 mr-2"></i> Giá: @Model.SelectedRooms[i].DonGia.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫/đêm</p>
                                            @if (Model.SelectedRooms[i].TotalPhuThu > 0)
                                            {
                                                <p class="text-gray-600 mb-2"><i class="fas fa-exclamation-circle text-rose-500 mr-2"></i> Phụ thu: @Model.SelectedRooms[i].TotalPhuThu.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫</p>
                                            }
                                            <p class="text-gray-600"><i class="fas fa-receipt text-rose-500 mr-2"></i> Tổng: @((Model.SelectedRooms[i].DonGia * Model.NumberOfNights + Model.SelectedRooms[i].TotalPhuThu).ToString("N0", new System.Globalization.CultureInfo("vi-VN")))₫</p>
                                        </div>

                                        @if (numberOfRoom > 1)
                                        {
                                            <button type="button" class="remove-room-btn text-rose-600 hover:text-rose-800 font-medium flex items-center" data-room-id="@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(Model.SelectedRooms[i].MaPhong))">
                                                <i class="fas fa-trash-alt mr-2"></i> Bỏ chọn
                                            </button>
                                        }

                                        <div class="mt-6 pt-4 border-t border-gray-200">
                                            <h5 class="font-medium text-gray-900 mb-3 flex items-center">
                                                <i class="fas fa-concierge-bell text-rose-500 mr-2"></i> Dịch vụ đi kèm
                                            </h5>

                                            @if (services != null)
                                            {
                                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                                    @foreach (var service in services)
                                                    {
                                                        <div class="bg-gray-50 p-3 rounded-lg border border-gray-200">
                                                            <div class="flex items-center mb-2">
                                                                <input type="checkbox"
                                                                       name="serviceSelected"
                                                                       value="@service.Ma_DV"
                                                                       id="select_@(Model.SelectedRooms[i].MaPhong)_@(service.Ma_DV)"
                                                                       class="rounded text-rose-500 focus:ring-rose-500 mr-2" />
                                                                <label for="select_@(Model.SelectedRooms[i].MaPhong)_@(service.Ma_DV)" class="font-medium">@service.Ten_DV</label>
                                                            </div>
                                                            <div class="flex items-center">
                                                                <input type="number"
                                                                       name="serviceQuantities"
                                                                       min="1"
                                                                       value="1"
                                                                       disabled
                                                                       id="quantity_@(Model.SelectedRooms[i].MaPhong)_@(service.Ma_DV)"
                                                                       class="w-16 p-2 border border-gray-300 rounded-lg focus:ring-rose-500 focus:border-rose-500 disabled:bg-gray-100 mr-2" />
                                                                <span class="text-sm text-gray-600">x @service.DonGia.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫/ngày</span>
                                                            </div>
                                                            <input type="hidden"
                                                                   name="serviceIds"
                                                                   value="@service.Ma_DV"
                                                                   id="id_@(Model.SelectedRooms[i].MaPhong)_@(service.Ma_DV)" />
                                                            <input type="hidden"
                                                                   id="price_@(Model.SelectedRooms[i].MaPhong)_@(service.Ma_DV)"
                                                                   value="@service.DonGia" />
                                                        </div>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="bg-gray-50 p-4 rounded-lg text-center">
                                                    <i class="fas fa-info-circle text-gray-400 mr-2"></i>
                                                    <span class="text-gray-600">Không có dịch vụ nào khả dụng</span>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <div class="mb-8 text-center">
                        <a asp-controller="Homestay"
                           asp-action="Details"
                           asp-route-id="@Model.HomestayId"
                           asp-route-checkInDate="@Model.CheckInDate.ToString("yyyy-MM-dd")"
                           asp-route-checkOutDate="@Model.CheckOutDate.ToString("yyyy-MM-dd")"
                           class="inline-flex items-center bg-rose-100 hover:bg-rose-200 text-rose-600 px-6 py-3 rounded-lg font-medium transition-colors shadow hover:shadow-md">
                            <i class="fas fa-plus mr-2"></i> Đặt thêm phòng
                        </a>
                    </div>

                    <div class="flex justify-center">
                        <button type="submit" class="bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white px-8 py-3 rounded-lg font-medium transition-all shadow-lg hover:shadow-xl flex items-center">
                            <i class="fas fa-check-circle mr-2"></i> Xác nhận đặt phòng
                        </button>
                    </div>
                </form>
            </div>

            <!-- Phần tổng hợp thanh toán -->
            <div class="lg:w-1/3">
                <div class="bg-white rounded-2xl shadow-xl p-6 sticky top-6">
                    <h3 class="text-xl font-semibold text-gray-900 font-lora mb-6 pb-2 border-b border-gray-200">Tóm tắt đặt phòng</h3>

                    <div class="space-y-4 mb-6 summary-info">
                        <div class="flex justify-between">
                            <span class="text-gray-600">Số phòng:</span>
                            <span class="font-medium">@Model.SelectedRooms.Count</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Số đêm:</span>
                            <span class="font-medium">@Model.NumberOfNights</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Ngày nhận phòng:</span>
                            <span class="font-medium">@Model.CheckInDate.ToString("dd/MM/yyyy")</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-gray-600">Ngày trả phòng:</span>
                            <span class="font-medium">@Model.CheckOutDate.ToString("dd/MM/yyyy")</span>
                        </div>
                    </div>

                    <div class="border-t border-gray-200 pt-4 mb-6">
                        <h4 class="font-medium text-gray-900 mb-4">Chi tiết giá</h4>

                        <div class="summary-room-details">
                            @foreach (var room in Model.SelectedRooms)
                            {
                                <div class="mb-3" data-room-id="@room.MaPhong">
                                    <div class="flex justify-between mb-1">
                                        <span class="text-gray-600">@room.TenPhong</span>
                                        <span class="font-medium">@((room.DonGia * Model.NumberOfNights + room.TotalPhuThu).ToString("N0", new System.Globalization.CultureInfo("vi-VN")))₫</span>
                                    </div>
                                    <div class="text-sm text-gray-500 ml-4">
                                        @room.DonGia.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫ x @Model.NumberOfNights đêm
                                        @if (room.TotalPhuThu > 0)
                                        {
                                            <div>+ @room.TotalPhuThu.ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫ phụ thu</div>
                                        }
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="mt-4 pt-4 border-t border-gray-200 summary-totals">
                            <div class="flex justify-between mb-2">
                                <span class="text-gray-600">Tổng giá phòng:</span>
                                <span class="font-medium">@Model.SelectedRooms.Sum(r => r.DonGia * Model.NumberOfNights).ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫</span>
                            </div>
                            @if (Model.SelectedRooms.Sum(r => r.TotalPhuThu) > 0)
                            {
                                <div class="flex justify-between mb-2 total-phu-thu">
                                    <span class="text-gray-600">Tổng phụ thu:</span>
                                    <span class="font-medium">@Model.SelectedRooms.Sum(r => r.TotalPhuThu).ToString("N0", new System.Globalization.CultureInfo("vi-VN"))₫</span>
                                </div>
                            }
                            <div class="flex justify-between text-lg font-bold text-rose-600 mt-3">
                                <span>Tổng cộng:</span>
                                <span>@(Model.SelectedRooms.Sum(r => (r.DonGia * Model.NumberOfNights + r.TotalPhuThu)).ToString("N0", new System.Globalization.CultureInfo("vi-VN")))₫</span>
                            </div>
                        </div>
                    </div>

                    <div class="bg-rose-50 border-l-4 border-rose-500 p-4 rounded-r-lg mb-6">
                        <div class="flex">
                            <div class="flex-shrink-0">
                                <i class="fas fa-info-circle text-rose-500"></i>
                            </div>
                            <div class="ml-3">
                                <p class="text-sm text-rose-700">
                                    Giá phòng có thể tăng do phụ thu vào một số ngày đặc biệt
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Modal xác nhận -->
<div id="confirmModal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50 px-4">
    <div class="bg-white rounded-2xl p-6 w-full max-w-3xl max-h-[90vh] overflow-y-auto shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-900 font-lora">Xác nhận đặt phòng</h2>
            <button id="cancelConfirm" class="text-gray-400 hover:text-gray-500">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>
        <div id="confirmContent" class="space-y-6">
            <!-- Nội dung modal sẽ được render bằng JS -->
        </div>
        <!-- Phần chọn khuyến mãi -->
        <div class="bg-gray-50 p-4 rounded-lg mt-6">
            <h3 class="text-lg font-medium text-gray-900 mb-3">Chọn khuyến mãi</h3>
            <select id="promotionSelect" class="w-full p-3 border border-gray-300 rounded-lg focus:ring-rose-500 focus:border-rose-500">
                <option value="">Không áp dụng khuyến mãi</option>
                <!-- Danh sách khuyến mãi sẽ được thêm bằng JS -->
            </select>
            <p id="promotionMessage" class="text-sm text-gray-600 mt-2 hidden"></p>
        </div>
        <div class="flex justify-end mt-8 space-x-3">
            <button id="cancelConfirmBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-2 rounded-lg font-medium transition-colors">
                Hủy
            </button>
            <button id="submitConfirm" class="bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white px-6 py-2 rounded-lg font-medium transition-all shadow hover:shadow-lg flex items-center">
                <i class="fas fa-check-circle mr-2"></i> Xác nhận
            </button>
        </div>
    </div>
</div>

<!-- Modal thanh toán -->
<div id="paymentModal" class="fixed inset-0 bg-black/50 flex items-center justify-center hidden z-50 px-4">
    <div class="bg-white rounded-2xl p-6 w-full max-w-3xl max-h-[90vh] overflow-y-auto shadow-2xl">
        <div class="flex justify-between items-center mb-6">
            <h2 class="text-2xl font-bold text-gray-900 font-lora">Thanh toán hóa đơn</h2>
            <button id="cancelPayment" class="text-gray-400 hover:text-gray-500">
                <i class="fas fa-times text-xl"></i>
            </button>
        </div>

        <div id="paymentContent" class="space-y-6 mb-8"></div>

        <form id="paymentForm" asp-action="ProcessPayment" asp-controller="Booking" method="post" class="space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" id="maHD" name="maHD" />

            <div class="bg-rose-50 border-l-4 border-rose-500 p-4 rounded-r-lg mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <i class="fas fa-info-circle text-rose-500"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-rose-700">
                            Bạn chỉ cần thanh toán 15% tiền phòng, phần còn lại sẽ phải thanh toán khi trả phòng
                        </p>
                    </div>
                </div>
            </div>

            <div>
                <h3 class="text-lg font-medium text-gray-900 mb-4">Phương thức thanh toán</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <input type="radio" id="vnpay" name="phuongThuc" value="VNPay" class="hidden peer" checked>
                        <label for="vnpay" class="flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer peer-checked:border-rose-500 peer-checked:bg-rose-50">
                            <div class="w-10 h-10 mr-4 bg-blue-50 rounded-full flex items-center justify-center">
                                <img src="https://vnpay.vn/s1/statics.vnpay.vn/2023/9/06ncktiwd6dc1694418196384.png" alt="VNPay" class="w-8 h-8">
                            </div>
                            <div>
                                <h4 class="font-medium">VNPay</h4>
                                <p class="text-sm text-gray-500">Thanh toán qua cổng VNPay</p>
                            </div>
                        </label>
                    </div>

                    <div>
                        <input type="radio" id="momo" name="phuongThuc" value="MoMo" class="hidden peer">
                        <label for="momo" class="flex items-center p-4 border border-gray-200 rounded-lg cursor-pointer peer-checked:border-rose-500 peer-checked:bg-rose-50">
                            <div class="w-10 h-10 mr-4 bg-pink-50 rounded-full flex items-center justify-center">
                                <img src="https://cdn.haitrieu.com/wp-content/uploads/2022/10/Logo-MoMo-Square.png" alt="MoMo" class="w-8 h-8">
                            </div>
                            <div>
                                <h4 class="font-medium">MoMo</h4>
                                <p class="text-sm text-rose-500">Ví điện tử MoMo</p>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            <div class="bg-gray-50 p-4 rounded-lg hidden" >
                <label for="soTien" class="block text-sm font-medium text-gray-700 mb-1">Số tiền thanh toán</label>
                <div class="relative">
                    <input type="number" id="soTien" name="soTien" class="w-full p-3 border border-gray-300 rounded-lg bg-white font-medium text-lg" readonly />
                    <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                        <span class="text-gray-500">₫</span>
                    </div>
                </div>
            </div>

            <div class="flex justify-end space-x-3 pt-4">
                <button type="button" id="cancelPaymentBtn" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-6 py-3 rounded-lg font-medium transition-colors">
                    Hủy
                </button>
                <button type="submit" id="submitPayment" class="bg-gradient-to-r from-rose-500 to-rose-600 hover:from-rose-600 hover:to-rose-700 text-white px-6 py-3 rounded-lg font-medium transition-all shadow hover:shadow-lg flex items-center">
                    <i class="fas fa-wallet mr-2"></i> Thanh toán ngay
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Biến toàn cục để lưu trữ selectedServices ban đầu
        let originalSelectedServices = {};

        // Hàm lưu trữ selectedServices ban đầu khi người dùng chọn dịch vụ
        function saveOriginalServices() {
            originalSelectedServices = {};
            document.querySelectorAll('[id^="room_"]').forEach(roomElement => {
                const maPhong = roomElement.querySelector('.room-input').dataset.maPhong;
                const services = [];
                const checkboxes = roomElement.querySelectorAll('input[name="serviceSelected"]:checked');
                checkboxes.forEach(checkbox => {
                    const serviceId = checkbox.value;
                    const quantityInput = document.getElementById(checkbox.id.replace('select_', 'quantity_'));
                    const quantity = parseInt(quantityInput.value);
                    if (quantity >= 1) {
                        const priceInput = document.getElementById(checkbox.id.replace('select_', 'price_'));
                        const price = parseFloat(priceInput.value);
                        const label = roomElement.querySelector(`label[for="${checkbox.id}"]`);

                        services.push({
                            maDV: serviceId,
                            tenDV: label.textContent,
                            donGia: price,
                            soLuong: quantity
                        });
                    }
                });
                originalSelectedServices[maPhong] = services;
            });
            console.log('Original Selected Services Saved:', originalSelectedServices);
        }

        // Hàm thoát HTML để tránh XSS
        function escapeHtml(str) {
            if (!str) return '';
            return str
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#039;");
        }

        // Hàm định dạng tiền tệ
        function formatCurrency(amount) {
            return amount.toLocaleString('vi-VN', { style: 'currency', currency: 'VND' });
        }

        // Hàm hiển thị toast
        function showToast(message, isSuccess, callback) {
            const escapedMessage = message.replace(/'/g, "\\'").replace(/"/g, '\\"').replace(/\n/g, ' ');
            Swal.fire({
                icon: isSuccess ? 'success' : 'error',
                title: escapedMessage,
                toast: true,
                position: 'top-end',
                showConfirmButton: false,
                timer: 3000,
                timerProgressBar: true,
                didOpen: (toast) => {
                    toast.addEventListener('mouseenter', Swal.stopTimer);
                    toast.addEventListener('mouseleave', Swal.resumeTimer);
                }
            }).then(() => {
                if (callback && typeof callback === 'function') callback();
            });
        }

        // Hàm lấy dữ liệu đặt phòng từ form
        function getBookingData() {
            const rooms = [];
            document.querySelectorAll('[id^="room_"]').forEach(roomElement => {
                const roomInputs = roomElement.querySelectorAll('.room-input');
                const maPhong = roomInputs[0].dataset.maPhong;
                const roomData = {
                    maPhong: maPhong,
                    tenPhong: roomInputs[1].dataset.tenPhong,
                    donGia: parseFloat(roomInputs[2].dataset.donGia),
                    hinhAnh: roomInputs[3].dataset.hinhAnh,
                    totalPhuThu: parseFloat(roomInputs[4].dataset.totalPhuThu || '0'),
                    selectedServices: originalSelectedServices[maPhong] || []
                };

                rooms.push(roomData);
            });

            const bookingData = {
                homestayId: '@Model.HomestayId',
